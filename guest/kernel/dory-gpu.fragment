# Apple Silicon hosts use a 16 KiB hypervisor granule; the guest must use 16 KiB pages so
# virtio-gpu host-visible blob offsets are hv_vm_map-aligned (Venus maps fail otherwise).
CONFIG_ARM64_16K_PAGES=y

# Experimental Venus renderer support layered on dory-virtual-display.fragment.
CONFIG_DMABUF_HEAPS=y
CONFIG_UDMABUF=y

CONFIG_DRM_FBDEV_EMULATION=n
CONFIG_FB=n
CONFIG_FB_VIRTUAL=n
