#!/bin/bash
set -euo pipefail

set_xfce_value() {
  local path="$1" type="$2" value="$3"
  if xfconf-query --channel xsettings --property "$path" >/dev/null 2>&1; then
    xfconf-query --channel xsettings --property "$path" --set "$value"
  else
    xfconf-query --channel xsettings --property "$path" --create --type "$type" --set "$value"
  fi
}

follow_preferred_display_mode() {
  local current_mode output_name preferred_mode snapshot

  while :; do
    if snapshot="$(xrandr --query 2>/dev/null)"; then
      output_name="$(awk '$2 == "connected" { print $1; exit }' <<<"$snapshot")"
      preferred_mode="$(awk '$1 ~ /^[0-9]+x[0-9]+$/ && index($0, "+") { print $1; exit }' <<<"$snapshot")"
      current_mode="$(awk '$1 ~ /^[0-9]+x[0-9]+$/ && index($0, "*") { print $1; exit }' <<<"$snapshot")"

      if [[ -n "$output_name" && -n "$preferred_mode" && "$preferred_mode" != "$current_mode" ]]; then
        xrandr --output "$output_name" --mode "$preferred_mode" >/dev/null 2>&1 || true
      fi
    fi
    sleep 1
  done
}

for _ in $(seq 1 100); do
  if xfconf-query --channel xsettings --list >/dev/null 2>&1; then
    set_xfce_value /Gdk/WindowScalingFactor int 2
    set_xfce_value /Xft/Antialias int 1
    set_xfce_value /Xft/Hinting int 1
    set_xfce_value /Xft/HintStyle string hintslight
    set_xfce_value /Xft/RGBA string rgb
    follow_preferred_display_mode
  fi
  sleep 0.1
done

exit 1
