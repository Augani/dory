agent_guide_text() {
  cat <<'EOF'
Dory agent guide v1

Use `dory agent guide --json` for the stable machine-readable contract.
Prefer `--json` on readiness, doctor, network, mount, disk, cleanup, routes, compat, repair, and idle commands.
doryd reconciles host tools automatically while it is running; do not run `dory install` for first use.
Use `dory machine exec NAME --json -- CMD` for structured machine command results.
Run read-only checks first; use `--apply` only for explicit repair/cleanup writes.
Available agent-native primitive: `dory wait`.
Available agent-native primitive: `dory events --follow --json`.
Available agent-native primitive: `dory mcp serve [--read-only]`.
Supported agent-native primitive: `dory sandbox run [--json] --mount . -- CMD` (dedicated VM, no host sharing by default).
Read-only machine backup inspection: `dory machine backup status [NAME]`.
EOF
}

agent_cmd() {
  case "${1:-guide}" in
    guide)
      shift || true
      local format="json"
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --json) format="json"; shift ;;
          --text) format="text"; shift ;;
          -h|--help) echo "usage: dory agent guide [--json|--text]"; return 0 ;;
          *) echo "unknown agent guide option: $1" >&2; exit 2 ;;
        esac
      done
      if [ "$format" = "json" ]; then
        agent_guide_json
      else
        agent_guide_text
      fi
      ;;
    *) echo "usage: dory agent guide [--json|--text]" >&2; exit 2 ;;
  esac
}

readiness_cmd() {
  local json=0 ctl tmp rc=0
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) echo "usage: dory readiness [--json]"; return 0 ;;
      *) echo "unknown readiness option: $1" >&2; return 2 ;;
    esac
  done
  ctl="$(dorydctl_bin 2>/dev/null)" || { echo "dorydctl not found; reinstall Dory Docker Core" >&2; return 1; }
  tmp="$(mktemp -t dory-readiness.XXXXXX)"
  if ! "$ctl" health > "$tmp"; then rm -f "$tmp"; return 1; fi
  python3 - "$tmp" "$json" <<'PY' || rc=$?
import json
import sys

report = json.load(open(sys.argv[1], encoding="utf-8"))
readiness = report.get("readiness")
if not isinstance(readiness, dict) or readiness.get("schema") != "dev.dory.readiness":
    raise SystemExit("doryd did not return the v0.4 readiness contract")
if sys.argv[2] == "1":
    print(json.dumps(readiness, separators=(",", ":"), sort_keys=True))
else:
    print(f"Runtime readiness: {readiness.get('overall', 'unknown')} ({readiness.get('trigger', 'unknown')})")
    for stage in readiness.get("stages", []):
        elapsed = stage.get("elapsedMilliseconds")
        timing = "" if elapsed is None else f" {elapsed}ms"
        print(f"  {stage.get('state', 'unknown'):8} {stage.get('title', stage.get('id', 'stage'))}{timing}")
        print(f"           {stage.get('reasonCode', 'unknown')}: {stage.get('detail', '')}")
        if stage.get("state") in {"blocked", "degraded"}:
            repair = stage.get("repair", {})
            print(f"           repair owner={repair.get('owner', 'unknown')}; mutation={repair.get('mutation', 'unspecified')}")
if readiness.get("overall") == "blocked":
    raise SystemExit(1)
PY
  rm -f "$tmp"
  return "$rc"
}

case "${1:-help}" in
  help|-h|--help) usage ;;
  version|--version) printf '%s\n' "$DORY_CLI_VERSION" ;;
  install)        shift; install_cmd install "$@" ;;
  uninstall)      shift; install_cmd uninstall "$@" ;;
  doctor)         shift; doctor_cmd doctor "$@" ;;
  readiness)      shift; readiness_cmd "$@" ;;
  support)        shift; support_cmd "$@" ;;
  logs)           shift; logs_cmd "$@" ;;
  network)        shift; network_cmd "$@" ;;
  mount)          shift; doctor_cmd mount "$@" ;;
  disk)           shift; doctor_cmd disk "$@" ;;
  cleanup)        shift; doctor_cmd cleanup "$@" ;;
  routes)         shift; doctor_cmd routes "$@" ;;
  compat)         shift; doctor_cmd compat "$@" ;;
  incidents)      shift; doctor_cmd incidents "$@" ;;
  repair)         shift; doctor_cmd repair "$@" ;;
  mode)           shift; mode_cmd "$@" ;;
  idle)
                  shift
                  case "${1:-status}" in
                    status) shift || true; idle_status_cmd "$@" ;;
                    set) shift || true; idle_set_cmd "$@" ;;
                    --json|-h|--help) idle_status_cmd "$@" ;;
                    history) shift || true; idle_history_cmd "$@" ;;
                    proxy-status|proxy-state) shift || true; idle_proxy_status_cmd "$@" ;;
                    proxy|launch-agent) idle_retired_cmd "$1" ;;
                    *) doctor_cmd idle "$@" ;;
                  esac ;;
  engine)         shift; engine_cmd "$@" ;;
  data)           shift; data_cmd "$@" ;;
  upgrade)        shift; upgrade_cmd "$@" ;;
  component)      shift; component_cmd "$@" ;;
  agent)          shift; agent_cmd "$@" ;;
  mcp)            shift; mcp_cmd "$@" ;;
  sandbox)        shift; sandbox_cmd "$@" ;;
  wait)           shift; wait_cmd "$@" ;;
  events)         shift; events_cmd "$@" ;;
  bundle)         shift; doctor_cmd bundle "$@" ;;
  shell)          shift; sh_name="${1:-}"; [ -n "$sh_name" ] || { echo "usage: dory shell <container>" >&2; exit 2; }; exec "$DOCKER_BIN" -H "unix://$DORY_SOCK" exec -it "$sh_name" sh -c 'command -v bash >/dev/null && exec bash || exec sh' ;;
  debug)          shift; debug_cmd "$@" ;;
  machine)        shift; machine_cmd "$@" ;;
  recipe)         shift
                  case "${1:-ls}" in
                    ls) recipe_ls ;;
                    show) shift; recipe_show "$@" ;;
                    add) shift; recipe_add "$@" ;;
                    new) shift; recipe_new "$@" ;;
                    *) echo "usage: dory recipe ls|show|add|new" >&2; exit 2 ;;
                  esac ;;
  usb)            shift; usb_cmd "$@" ;;
  expose)         shift; expose_cmd "$@" ;;
  ssh)            shift
                  name="${1:?usage: dory ssh <machine>}"
                  if ctl="$(dorydctl_bin 2>/dev/null)"; then
                    exec "$ctl" machine shell "$name"
                  fi
                  if [ "${DORY_LEGACY_DOCKER_MACHINES:-0}" != "1" ]; then
                    echo "dory ssh requires dorydctl and Dory's daemon-managed VM machine runtime. Start Dory's engine; set DORY_LEGACY_DOCKER_MACHINES=1 only to inspect old container-backed machines." >&2
                    exit 1
                  fi
                  cid="dory-machine-$name"
                  user="$("$DOCKER_BIN" -H "unix://$DORY_SOCK" inspect -f '{{index .Config.Labels "dory.machine.user"}}' "$cid" 2>/dev/null || true)"; user="${user:-root}"
                  shell="$("$DOCKER_BIN" -H "unix://$DORY_SOCK" inspect -f '{{index .Config.Labels "dory.machine.shell"}}' "$cid" 2>/dev/null || true)"; shell="${shell:-/bin/sh}"
                  home="$("$DOCKER_BIN" -H "unix://$DORY_SOCK" inspect -f '{{index .Config.Labels "dory.machine.home"}}' "$cid" 2>/dev/null || true)"
                  port="$("$DOCKER_BIN" -H "unix://$DORY_SOCK" inspect -f '{{index .Config.Labels "dory.machine.sshPort"}}' "$cid" 2>/dev/null || true)"
                  if [ -n "$port" ]; then
                    exec ssh -p "$port" -o StrictHostKeyChecking=accept-new "$user@localhost"
                  else
                    if [ -z "$home" ]; then if [ "$user" = "root" ]; then home="/root"; else home="/home/$user"; fi; fi
                    exec "$DOCKER_BIN" -H "unix://$DORY_SOCK" exec -it -u "$user" -w "$home" "$cid" "$shell" -l
                  fi ;;
  vm)             shift; H="$(vmm_helper || true)"; [ -z "$H" ] && { echo "dory-vmm helper not found; build+sign it (see scripts/bundle-engine.sh)" >&2; exit 1; }; exec "$H" "$@" ;;
  k8s)            shift
                  if ! [ -x "$KUBECTL_BIN" ] && ! command -v "$KUBECTL_BIN" >/dev/null 2>&1; then
                    echo "Kubernetes is not installed. Run: dory component install kubernetes" >&2
                    exit 1
                  fi
                  exec "$KUBECTL_BIN" --kubeconfig "$KUBECONFIG_DORY" "$@" ;;
  *)              exec "$DOCKER_BIN" -H "unix://$DORY_SOCK" "$@" ;;
esac
