def send(message: dict[str, Any]) -> None:
    sys.stdout.write(json.dumps(message, separators=(",", ":"), sort_keys=True) + "\n")
    sys.stdout.flush()


def success(request_id: Any, result: dict[str, Any]) -> None:
    send({"jsonrpc": "2.0", "id": request_id, "result": result})


def error(request_id: Any, code: int, message: str, data: Any = None) -> None:
    body: dict[str, Any] = {"code": code, "message": message}
    if data is not None:
        body["data"] = data
    send({"jsonrpc": "2.0", "id": request_id, "error": body})


def tool_result(value: Any, is_error: bool = False) -> dict[str, Any]:
    structured = value if isinstance(value, dict) else {"value": value}
    text = json.dumps(value, separators=(",", ":"), sort_keys=True) if not isinstance(value, str) else value
    return {
        "content": [{"type": "text", "text": text}],
        "structuredContent": structured,
        "isError": is_error,
    }


def tool_error(message: str, data: Any = None) -> dict[str, Any]:
    body = {"error": message}
    if data is not None:
        body["data"] = data
    return tool_result(body, is_error=True)


def run_cli(args: list[str], timeout: int = 90, expect_json: bool = True) -> Any:
    proc = subprocess.run(
        [CLI] + args,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        timeout=timeout,
        env=os.environ.copy(),
    )
    if expect_json:
        try:
            parsed = json.loads(proc.stdout or "{}")
        except json.JSONDecodeError as exc:
            raise ToolExecutionError(f"dory {' '.join(args)} did not return JSON: {exc}; stderr={proc.stderr.strip()}") from exc
        if proc.returncode != 0:
            raise ToolExecutionError(proc.stderr.strip() or json.dumps(parsed, separators=(",", ":")))
        return parsed
    if proc.returncode != 0:
        raise ToolExecutionError(proc.stderr.strip() or proc.stdout.strip() or f"dory exited {proc.returncode}")
    return proc.stdout


def require_object(value: Any) -> dict[str, Any]:
    if value is None:
        return {}
    if not isinstance(value, dict):
        raise ToolExecutionError("arguments must be an object")
    return value


def int_arg(args: dict[str, Any], name: str, default: int, minimum: int, maximum: int) -> int:
    raw = args.get(name, default)
    if not isinstance(raw, int) or isinstance(raw, bool) or raw < minimum or raw > maximum:
        raise ToolExecutionError(f"{name} must be an integer between {minimum} and {maximum}")
    return raw


def string_arg(args: dict[str, Any], name: str, required: bool = False) -> str:
    raw = args.get(name, "")
    if required and not raw:
        raise ToolExecutionError(f"{name} is required")
    if raw and not isinstance(raw, str):
        raise ToolExecutionError(f"{name} must be a string")
    return raw


def call_tool(name: str, arguments: Any) -> dict[str, Any]:
    args = require_object(arguments)
    if name == "dory.agent_guide":
        return tool_result(run_cli(["agent", "guide", "--json"]))
    if name == "dory.doctor":
        command = ["doctor", "--json"]
        if args.get("active") is True:
            command.append("--active")
        only = string_arg(args, "only")
        if only:
            command.extend(["--only", only])
        return tool_result(run_cli(command))
    if name == "dory.compat":
        command = ["compat", "--json"]
        only = string_arg(args, "only")
        if only:
            command.extend(["--only", only])
        return tool_result(run_cli(command))
    if name == "dory.engine_status":
        return tool_result(run_cli(["engine", "status", "--json"]))
    if name == "dory.machine_list":
        return tool_result({"machines": run_cli(["machine", "list"])})
    if name == "dory.machine_exec":
        if READ_ONLY:
            return tool_error("dory.machine_exec is disabled because this MCP server is running in read-only mode")
        machine = string_arg(args, "name", required=True)
        command_value = args.get("command")
        if not isinstance(command_value, list) or not command_value or not all(isinstance(item, str) for item in command_value):
            raise ToolExecutionError("command must be a non-empty array of strings")
        command = ["machine", "exec", machine, "--json"]
        cwd = string_arg(args, "cwd")
        if cwd:
            command.extend(["--cwd", cwd])
        env = args.get("env", {})
        if env:
            if not isinstance(env, dict) or not all(isinstance(k, str) and isinstance(v, str) for k, v in env.items()):
                raise ToolExecutionError("env must be an object with string values")
            for key, value in sorted(env.items()):
                command.extend(["--env", f"{key}={value}"])
        timeout_seconds = int_arg(args, "timeoutSeconds", 30, 0, 600)
        output_limit = int_arg(args, "outputLimitBytes", 1024 * 1024, 0, 32 * 1024 * 1024)
        command.extend(["--timeout-ms", str(timeout_seconds * 1000)])
        command.extend(["--output-limit-bytes", str(output_limit)])
        command.extend(["--", *command_value])
        return tool_result(run_cli(command, timeout=max(10, timeout_seconds + 15)))
    if name == "dory.sandbox_run":
        if READ_ONLY:
            return tool_error("dory.sandbox_run is disabled because this MCP server is running in read-only mode")
        command_value = args.get("command")
        if not isinstance(command_value, list) or not command_value or not all(isinstance(item, str) for item in command_value):
            raise ToolExecutionError("command must be a non-empty array of strings")
        command = ["sandbox", "run", "--json"]
        reuse_name = string_arg(args, "reuse")
        sandbox_name = string_arg(args, "name")
        if reuse_name and sandbox_name:
            raise ToolExecutionError("use either name or reuse, not both")
        if reuse_name:
            command.extend(["--reuse", reuse_name])
        if sandbox_name:
            command.extend(["--name", sandbox_name])
        keep = args.get("keep", False)
        if not isinstance(keep, bool):
            raise ToolExecutionError("keep must be a boolean")
        if keep:
            command.append("--keep")
        network_policy = string_arg(args, "networkPolicy")
        if network_policy:
            if network_policy not in ("none", "outbound", "full"):
                raise ToolExecutionError("networkPolicy must be none, outbound, or full")
            command.extend(["--network", network_policy])
        allow_network = args.get("allowNetwork", [])
        if allow_network:
            if not isinstance(allow_network, list) or not all(isinstance(item, str) and item for item in allow_network):
                raise ToolExecutionError("allowNetwork must be an array of non-empty HOST[:PORT] strings")
            for destination in allow_network:
                command.extend(["--allow-network", destination])
        rollback = args.get("rollback", False)
        if not isinstance(rollback, bool):
            raise ToolExecutionError("rollback must be a boolean")
        if rollback:
            command.append("--rollback")
        if "ttlSeconds" in args:
            command.extend(["--ttl-seconds", str(int_arg(args, "ttlSeconds", 0, 0, 30 * 24 * 60 * 60))])
        mounts = args.get("mounts", [])
        if mounts:
            if not isinstance(mounts, list) or not all(isinstance(item, str) and item for item in mounts):
                raise ToolExecutionError("mounts must be an array of non-empty strings")
            for mount in mounts:
                command.extend(["--mount", mount])
        secret_names = args.get("secretEnvironmentNames", [])
        if secret_names:
            if not isinstance(secret_names, list) or not all(isinstance(item, str) and item for item in secret_names):
                raise ToolExecutionError("secretEnvironmentNames must be an array of environment names")
            for secret_name in secret_names:
                command.extend(["--secret-env", secret_name])
        for key, option in (("sshAgent", "--ssh-agent"), ("elevated", "--elevated")):
            value = args.get(key, False)
            if not isinstance(value, bool):
                raise ToolExecutionError(f"{key} must be a boolean")
            if value:
                command.append(option)
        wall_seconds = int_arg(args, "wallTimeSeconds", 600, 1, 600)
        if "wallTimeSeconds" in args:
            command.extend(["--wall-time-seconds", str(wall_seconds)])
        if "processes" in args:
            command.extend(["--processes", str(int_arg(args, "processes", 128, 1, 4096))])
        if "diskMB" in args:
            command.extend(["--disk-mb", str(int_arg(args, "diskMB", 256, 32, 640))])
        if "memoryMB" in args:
            command.extend(["--memory-mb", str(int_arg(args, "memoryMB", 2048, 1024, 16384))])
        if "cpus" in args:
            command.extend(["--cpus", str(int_arg(args, "cpus", 2, 1, 8))])
        command.extend(["--", *command_value])
        return tool_result(run_cli(command, timeout=wall_seconds + 180))
    if name == "dory.wait":
        target_kind = string_arg(args, "targetKind", required=True)
        if target_kind not in ("engine", "container", "machine"):
            raise ToolExecutionError("targetKind must be engine, container, or machine")
        command = ["wait", target_kind]
        if target_kind != "engine":
            command.append(string_arg(args, "name", required=True))
        command.extend(["--until", string_arg(args, "until", required=True)])
        timeout_seconds = int_arg(args, "timeoutSeconds", 60, 0, 3600)
        interval_seconds = int_arg(args, "intervalSeconds", 1, 1, 60)
        command.extend(["--timeout", str(timeout_seconds), "--interval", str(interval_seconds), "--json"])
        return tool_result(run_cli(command, timeout=max(10, timeout_seconds + 5)))
    if name == "dory.events":
        limit = int_arg(args, "limit", 50, 1, 500)
        return tool_result(run_cli(["events", "--json", "--limit", str(limit)]))
    raise ToolExecutionError(f"unknown tool: {name}")


def handle(request: dict[str, Any]) -> None:
    request_id = request.get("id")
    method = request.get("method")
    if not isinstance(method, str):
        error(request_id, -32600, "invalid request")
        return
    if method == "initialize":
        params = request.get("params") if isinstance(request.get("params"), dict) else {}
        requested = params.get("protocolVersion")
        success(request_id, {
            "protocolVersion": requested if requested in SUPPORTED_PROTOCOLS else PROTOCOL,
            "capabilities": {"tools": {"listChanged": False}},
            "serverInfo": {
                "name": "dory",
                "title": "Dory",
                "version": SERVER_VERSION,
                "description": "Dory local runtime MCP server wrapping the dory CLI.",
            },
            "instructions": "Use read-only tools first. dory.machine_exec is unavailable when the server is launched with --read-only.",
        })
    elif method == "notifications/initialized":
        return
    elif method == "ping":
        success(request_id, {})
    elif method == "tools/list":
        success(request_id, {"tools": TOOLS})
    elif method == "tools/call":
        params = request.get("params")
        if not isinstance(params, dict) or not isinstance(params.get("name"), str):
            error(request_id, -32602, "tools/call requires params.name")
            return
        try:
            success(request_id, call_tool(params["name"], params.get("arguments", {})))
        except ToolExecutionError as exc:
            success(request_id, tool_error(str(exc)))
        except subprocess.TimeoutExpired as exc:
            success(request_id, tool_error(f"tool timed out after {exc.timeout} seconds"))
    else:
        error(request_id, -32601, f"method not found: {method}")


for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        message = json.loads(line)
    except json.JSONDecodeError as exc:
        error(None, -32700, f"parse error: {exc}")
        continue
    if isinstance(message, list):
        for item in message:
            if isinstance(item, dict) and "id" in item:
                handle(item)
        continue
    if not isinstance(message, dict):
        error(None, -32600, "invalid request")
        continue
    if "id" not in message and message.get("method") != "notifications/initialized":
        continue
    handle(message)
PY
}

