#!/bin/bash
# `dory` — Dory's command-line companion (the analog of OrbStack's `orb`). Drives Dory's own engine,
# machines, and Kubernetes from the terminal. Install:  ln -sf "$PWD/scripts/dory" /usr/local/bin/dory
set -euo pipefail

# Resolve the real script directory THROUGH symlinks — `dory` is installed as a symlink at
# /usr/local/bin (or the Homebrew bin), and a plain `dirname "$0"` would then look for the
# dory-doctor helper and recipe dir next to the symlink instead of beside the
# real script. macOS ships no `readlink -f`, so follow the chain by hand.
DORY_SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -L "$DORY_SCRIPT_SOURCE" ]; do
  DORY_SCRIPT_DIR="$(cd -P "$(dirname "$DORY_SCRIPT_SOURCE")" >/dev/null 2>&1 && pwd)"
  DORY_SCRIPT_SOURCE="$(readlink "$DORY_SCRIPT_SOURCE")"
  case "$DORY_SCRIPT_SOURCE" in /*) ;; *) DORY_SCRIPT_SOURCE="$DORY_SCRIPT_DIR/$DORY_SCRIPT_SOURCE" ;; esac
done
DORY_SCRIPT_DIR="$(cd -P "$(dirname "$DORY_SCRIPT_SOURCE")" >/dev/null 2>&1 && pwd)"

DORY_CLI_VERSION="0.0.0-dev"
DORY_SOCK="${DORY_SOCK:-$HOME/.dory/dory.sock}"
KUBECONFIG_DORY="$HOME/.kube/dory-config"
RECIPE_DIR="${DORY_RECIPE_DIR:-$HOME/.dory/recipes}"
BUILTIN_RECIPE_DIR="${DORY_BUILTIN_RECIPE_DIR:-$(cd "$DORY_SCRIPT_DIR/.." && pwd)/Dory/Resources/Recipes}"

first_executable() {
  local cand
  for cand in "$@"; do
    [ -n "$cand" ] && [ -x "$cand" ] && { printf '%s\n' "$cand"; return 0; }
  done
  return 1
}

resolve_cli() {
  local name="$1"
  first_executable \
    "$DORY_SCRIPT_DIR/$name" \
    "$DORY_SCRIPT_DIR/../Helpers/$name" \
    "$HOME/.dory/bin/$name" \
    "$(command -v "$name" 2>/dev/null || true)"
}

CONTAINER_BIN="${DORY_CONTAINER_BIN:-$(resolve_cli container || printf '%s\n' /opt/homebrew/bin/container)}"
DOCKER_BIN="${DORY_DOCKER_BIN:-$(resolve_cli docker || printf '%s\n' docker)}"
DOCKER_BUILDX_BIN="${DORY_DOCKER_BUILDX_BIN:-$(resolve_cli docker-buildx || printf '%s\n' docker-buildx)}"
DOCKER_COMPOSE_BIN="${DORY_DOCKER_COMPOSE_BIN:-$(resolve_cli docker-compose || printf '%s\n' docker-compose)}"
KUBECTL_BIN="${DORY_KUBECTL_BIN:-$(resolve_cli kubectl || printf '%s\n' kubectl)}"

host_guest_arch() {
  [ "$(uname -m)" = "x86_64" ] && printf '%s\n' "amd64" || printf '%s\n' "arm64"
}

# The VMM helper bundled in the app and signed with the virtualization entitlement. Falls back to a
# local dev build for low-level debugging.
vmm_helper() {
  for p in "${DORY_VMM_HELPER:-}" \
           "$DORY_SCRIPT_DIR/../Helpers/dory-vmm" \
           "$DORY_SCRIPT_DIR/../dory-core-swift/.build/debug/dory-vmm"; do
    [ -n "$p" ] && [ -x "$p" ] && { echo "$p"; return; }
  done
}

hv_helper() {
  for p in "${DORY_HV_BIN:-}" \
           "$DORY_SCRIPT_DIR/../Helpers/dory-hv" \
           "$DORY_SCRIPT_DIR/../Packages/ContainerizationEngine/.build/debug/dory-hv" \
           "$DORY_SCRIPT_DIR/../Packages/ContainerizationEngine/.build/out/Products/Release/dory-hv" \
           "$DORY_SCRIPT_DIR/../Packages/ContainerizationEngine/.build/out/Products/Debug/dory-hv"; do
    [ -n "$p" ] && [ -x "$p" ] && { echo "$p"; return; }
  done
}

usage() {
  cat <<EOF
dory — Dory CLI

  dory <docker args...>        Run any docker command against Dory's engine
  dory install [--json] [--dry-run]
                               Manual recovery for docker, Compose, dory, and optional kubectl terminal integration
  dory uninstall [--json] [--dry-run]
                               Stop Dory services and remove runtime/shell integration; preserve workload data
  dory component list|install|update|verify|remove
                               Manage signed, removable Kubernetes, Linux Machines, and Desktop packs
  dory shell <container>       Open an interactive shell in a container
  dory debug <container> [-- cmd...]
                               Reserved for a future agent namespace-debug RPC (currently unavailable)
  dory machine <args...>       Manage doryd Linux VM machines (ls, create, start, stop, delete, run)
                               Delete/restore require --confirm with the exact machine or snapshot ID
  dory machine exec <name> [--json] -- <command...>
                               Run a command in a machine; --json emits schema v1 result metadata
  dory machine snapshot <name> Take a Dory machine snapshot
  dory machine restore <name> <tag|image>
                               Restore, clone, import, export, or delete snapshots
  dory machine backup [machine] <tag|image> <s3://bucket/prefix-or-file>
                               Export a snapshot image and upload it with aws s3 cp
  dory doctor [--json] [--active] [--bundle [PATH]] [--diff]
                               Diagnose socket, CLI, network, mounts, disk, memory, and helpers
                               (--diff shows what changed since the last healthy run)
  dory readiness [--json]      Show ordered app→doryd→VM→agent→disk→network→Docker→socket→Kubernetes state
  dory support bundle [--json] [--active] [PATH]
                               Write one redacted support zip and print the path for GitHub issues
  dory logs collect [--json] [--active] [PATH]
                               Alias for support bundle; no screenshots needed
  dory network [--json] [--active] [--probe HOST[:PORT]]
  dory network --save-probe HOST[:PORT] | --list-probes | --remove-probe HOST[:PORT]
                               Diagnose DNS, registry, proxy, ports, and *.dory.local routing
  dory network authorization-plan [--json]
                               Print doryd's resolver, pf, TLS, and low-port authorization plan
  dory network authorize [--json] [--dry-run|--apply]
                               Dry-run or apply doryd's local-domain and privileged-port plan
  dory network deauthorize [--json] [--dry-run|--apply]
                               Dry-run or remove Dory-owned system networking integration
  dory network --lan-visible on|off
                               Publish ports to the local network, or restrict to localhost
  dory network custom-domains
  dory network set-custom-domain HOST --published-port N
  dory network remove-custom-domain HOST
                               Manage custom HTTP/HTTPS hostnames routed to published ports
  dory mount [--json]           Validate bind mount read/write and host-edit visibility
  dory disk [--json]            Show host, Docker, Dory state, log, and VM disk usage
  dory cleanup [--json] [--apply] [--include-volumes]
                               Show or apply safe cleanup for stopped containers, cache, and logs
  dory routes [--json]          Show published ports and inferred *.dory.local routes
  dory compat [--json] [--only TOOLS]
                               Check tool compatibility (VS Code, Testcontainers, act, ...)
  dory compat --recipe [TOOL]  Show copy-paste setup recipes with verification commands
  dory repair [all|socket|context|dns|routes|domains|ports|dockerd|engine|guest-agent] [--apply]
                               Repair a subsystem; 'all' only acts on unhealthy ones with --apply
  dory mode [manual|auto-idle|always-on|battery-saver|show]
                               Show or set the runtime availability mode
  dory idle status [--json]     Explain whether Auto-Idle could sleep and what blocks it
  dory idle history [--json] [--limit N]
                               Show doryd Auto-Idle sleep/wake transitions
  dory engine sleep|wake|status
                               Stop, start, or check the headless engine
  dory data path               Print the selected .dorydrive path
  dory data backup <archive.dorybackup>
                               Back up the stopped Dory engine with sparse, verified chunks
  dory data verify <archive.dorybackup>
                               Verify every backup manifest, chunk, and completion marker
  dory data restore <archive.dorybackup> <target.dorydrive>
                               Restore to a new verified drive without replacing existing data
  dory data use <target.dorydrive>
                               Select a restored drive with the same durable drive identity
  dory data capacity [--json]  Show Docker disk logical capacity and physical allocation
  dory data grow GIB [--json]  Grow Docker storage safely (128–2048 GiB; shrinking is refused)
  dory upgrade status [--json]
                               Show the latest preflight/snapshot/smoke/rollback transaction
  dory upgrade recovery [--json]
                               Show the fail-closed data recovery export and exact verify/restore commands
  dory agent guide [--json|--text]
                               Emit a versioned CLI capability map for coding agents
  dory mcp serve [--read-only]
                               Serve Dory tools over stdio MCP for Claude/Cursor-style clients
  dory sandbox run [--json] [--keep] [--network MODE] [--allow-network HOST:PORT] -- <command...>
                               Run non-root in a dedicated VM; mounts default read-only and network
                               defaults denied. Use sandbox inspect/list/kill for retained runs.
  dory wait engine|container|machine [NAME] --until STATE --timeout N [--json]
                               Wait for a runtime state without hand-written polling loops
  dory events [--json] [--follow] [--limit N]
                               Show or stream idle transitions and runtime incidents
  dory usb ls                   Inspect host USB candidates (passthrough is not yet available)
  dory expose <port|machine> [--port P] [--hostname H] [--print-command]
                               Share a local port or machine endpoint through a public HTTPS tunnel
  dory k8s <kubectl args...>   Run kubectl against Dory's Kubernetes cluster
  dory ssh <machine>           SSH into a Linux machine as you (real ssh when available)
  dory vm [--image R] [--arch amd64|arm64] [--rosetta] [--mount h:g] -- <cmd>
                               Run a container on Dory's in-process framework engine
                               (Rosetta-fast x86 + host file mounts)
  dory vm --devices            Boot a VM with USB + audio passthrough and dynamic
                               memory ballooning (reclaims RAM to macOS)
  dory version                 Print the dory CLI version
  dory help                    Show this help
EOF
}

DORY_CLI_BEGIN="# >>> dory cli >>>"
DORY_CLI_END="# <<< dory cli <<<"
DORY_CLI_RESTORE_NO_NEWLINE="# dory:restore-no-trailing-newline"
DORY_CLI_REMOVE_EMPTY_PROFILE="# dory:remove-empty-profile"
DORY_CLI_PROFILES=(".zprofile" ".zshrc" ".bash_profile" ".bashrc" ".profile")

install_usage() {
  echo "usage: dory install|uninstall [--json] [--dry-run]" >&2
}

cli_tool_source() {
  local tool="$1"
  case "$tool" in
    docker)
      first_executable "${DORY_DOCKER_BIN:-}" "$DORY_SCRIPT_DIR/docker" "$DORY_SCRIPT_DIR/../Helpers/docker" "$HOME/.dory/bin/docker" "$(command -v docker 2>/dev/null || true)"
      ;;
    docker-compose)
      first_executable "${DORY_DOCKER_COMPOSE_BIN:-}" "$DORY_SCRIPT_DIR/docker-compose" "$DORY_SCRIPT_DIR/../Helpers/docker-compose" "$HOME/.docker/cli-plugins/docker-compose" "$HOME/.dory/bin/docker-compose" "$(command -v docker-compose 2>/dev/null || true)"
      ;;
    docker-buildx)
      first_executable "${DORY_DOCKER_BUILDX_BIN:-}" "$DORY_SCRIPT_DIR/docker-buildx" "$DORY_SCRIPT_DIR/../Helpers/docker-buildx" "$HOME/.docker/cli-plugins/docker-buildx" "$HOME/.dory/bin/docker-buildx" "$(command -v docker-buildx 2>/dev/null || true)"
      ;;
    kubectl)
      first_executable "${DORY_KUBECTL_BIN:-}" "$DORY_SCRIPT_DIR/kubectl" "$DORY_SCRIPT_DIR/../Helpers/kubectl" "$HOME/.dory/bin/kubectl" "$(command -v kubectl 2>/dev/null || true)"
      ;;
    dory)
      first_executable "$DORY_SCRIPT_DIR/dory" "$DORY_SCRIPT_SOURCE" "$HOME/.dory/bin/dory" "$(command -v dory 2>/dev/null || true)"
      ;;
    dory-doctor)
      first_executable "${DORY_DOCTOR_BIN:-}" "$DORY_SCRIPT_DIR/dory-doctor" "$DORY_SCRIPT_DIR/../Helpers/dory-doctor" "$HOME/.dory/bin/dory-doctor" "$(command -v dory-doctor 2>/dev/null || true)"
      ;;
    dorydctl)
      first_executable "${DORYDCTL_BIN:-}" "$DORY_SCRIPT_DIR/dorydctl" "$DORY_SCRIPT_DIR/../Helpers/dorydctl" "$HOME/.dory/bin/dorydctl" "$(command -v dorydctl 2>/dev/null || true)"
      ;;
    *)
      return 1
      ;;
  esac
}

cli_path_block() {
  local restore_no_newline="${1:-0}" remove_empty_profile="${2:-0}"
  printf '%s\n' "$DORY_CLI_BEGIN"
  [ "$restore_no_newline" -eq 0 ] || printf '%s\n' "$DORY_CLI_RESTORE_NO_NEWLINE"
  [ "$remove_empty_profile" -eq 0 ] || printf '%s\n' "$DORY_CLI_REMOVE_EMPTY_PROFILE"
  printf 'export PATH="%s:$PATH"\n%s\n' "$HOME/.dory/bin" "$DORY_CLI_END"
}

profile_contains_dory_block() {
  local profile="$1"
  [ -f "$profile" ] && grep -Fq "$DORY_CLI_BEGIN" "$profile"
}

profile_has_well_formed_dory_blocks() {
  local profile="$1"
  awk -v begin="$DORY_CLI_BEGIN" -v end="$DORY_CLI_END" '
    $0 == begin {
      if (inside) exit 1
      inside = 1
      count += 1
      next
    }
    $0 == end {
      if (!inside) exit 1
      inside = 0
      next
    }
    END {
      if (inside || count == 0) exit 1
    }
  ' "$profile"
}

profile_write_target() {
  local profile="$1" resolved
  resolved="$(realpath "$profile" 2>/dev/null || true)"
  [ -n "$resolved" ] && [ -f "$resolved" ] && printf '%s\n' "$resolved" || printf '%s\n' "$profile"
}

replace_profile() {
  local profile="$1" content="$2" target tmp
  target="$(profile_write_target "$profile")"
  tmp="$(mktemp "${target}.dory.XXXXXX")"
  if [ -f "$target" ]; then
    /bin/cp -p "$target" "$tmp"
  else
    chmod 600 "$tmp"
  fi
  printf '%s' "$content" > "$tmp"
  mv "$tmp" "$target"
}

install_path_block() {
  local dry_run="$1" profile content block separator restore_no_newline updated_any=0 saw_profile=0
  for name in "${DORY_CLI_PROFILES[@]}"; do
    profile="$HOME/$name"
    [ -e "$profile" ] || continue
    saw_profile=1
    if profile_contains_dory_block "$profile"; then
      profile_has_well_formed_dory_blocks "$profile" \
        || echo "Dory left malformed shell markers untouched in $profile" >&2
      continue
    fi
    updated_any=1
    if [ "$dry_run" -eq 1 ]; then
      continue
    fi
    content="$(cat "$profile" 2>/dev/null; printf x)"
    content="${content%x}"
    separator=""
    restore_no_newline=0
    case "$content" in
      ""|*$'\n') ;;
      *) separator=$'\n'; restore_no_newline=1 ;;
    esac
    block="$(cli_path_block "$restore_no_newline" 0)"
    content="${content}${separator}${block}"$'\n'
    replace_profile "$profile" "$content"
  done
  if [ "$saw_profile" -eq 0 ]; then
    updated_any=1
    [ "$dry_run" -eq 1 ] || cli_path_block 0 1 > "$HOME/.zprofile"
  fi
  [ "$updated_any" -eq 1 ]
}

remove_path_blocks() {
  local dry_run="$1" profile target stripped remove_empty_profile changed=0
  for name in "${DORY_CLI_PROFILES[@]}"; do
    profile="$HOME/$name"
    profile_contains_dory_block "$profile" || continue
    if ! profile_has_well_formed_dory_blocks "$profile"; then
      echo "Dory left malformed shell markers untouched in $profile" >&2
      continue
    fi
    changed=1
    [ "$dry_run" -eq 1 ] && continue
    remove_empty_profile=0
    grep -Fq "$DORY_CLI_REMOVE_EMPTY_PROFILE" "$profile" && remove_empty_profile=1
    stripped="$(python3 - "$profile" \
      "$DORY_CLI_BEGIN" "$DORY_CLI_END" "$DORY_CLI_RESTORE_NO_NEWLINE" <<'PY'
import sys

path, begin, end, restore_marker = sys.argv[1:5]
with open(path, encoding="utf-8", newline="") as handle:
    lines = handle.read().splitlines(keepends=True)
output = []
inside = False
restore = False
trim_final_separator = False
for index, raw in enumerate(lines):
    line = raw.rstrip("\r\n")
    if line == begin:
        if inside:
            raise SystemExit(2)
        inside = True
        restore = False
        continue
    if line == end:
        if not inside:
            raise SystemExit(2)
        inside = False
        trim_final_separator = restore and index == len(lines) - 1
        continue
    if inside:
        restore = restore or line == restore_marker
        continue
    output.append(raw)
if inside:
    raise SystemExit(2)
result = "".join(output)
if trim_final_separator and result.endswith("\n"):
    result = result[:-1]
sys.stdout.write(result)
PY
    printf x)"
    stripped="${stripped%x}"
    target="$(profile_write_target "$profile")"
    if [ "$remove_empty_profile" -eq 1 ] && [ -z "$stripped" ] && [ ! -L "$profile" ]; then
      rm -f "$target"
    else
      replace_profile "$profile" "$stripped"
    fi
  done
  [ "$changed" -eq 1 ]
}

remove_dory_launch_agent() {
  local dry_run="$1" plist="$HOME/Library/LaunchAgents/dev.dory.doryd.plist"
  local launchctl_bin="${DORY_LAUNCHCTL_BIN:-/bin/launchctl}" service output label program
  service="gui/$(id -u)/dev.dory.doryd"
  if [ "$dry_run" -eq 0 ]; then
    if ! output="$("$launchctl_bin" bootout "$service" 2>&1)"; then
      case "$output" in
        *"No such process"*|*"Could not find service"*) ;;
        *) echo "Dory could not stop its LaunchAgent: $output" >&2; return 1 ;;
      esac
    fi
  fi
  [ -e "$plist" ] || [ -L "$plist" ] || return 0
  if [ -L "$plist" ]; then
    echo "Dory left a symlinked LaunchAgent untouched: $plist" >&2
    return 1
  fi
  label="$(/usr/bin/plutil -extract Label raw -o - "$plist" 2>/dev/null || true)"
  program="$(/usr/bin/plutil -extract ProgramArguments.0 raw -o - "$plist" 2>/dev/null || true)"
  if [ "$label" != dev.dory.doryd ]; then
    echo "Dory left a LaunchAgent with an unexpected label untouched: $plist" >&2
    return 1
  fi
  case "$program" in
    */Dory.app/Contents/Helpers/doryd) ;;
    *) echo "Dory left a LaunchAgent with an unexpected program untouched: $plist" >&2; return 1 ;;
  esac
  [ "$dry_run" -eq 1 ] || rm -f "$plist"
}

unregister_privileged_network_helper() {
  local dry_run="$1" app_bin="${DORY_APP_BIN:-$DORY_SCRIPT_DIR/../MacOS/Dory}" output
  [ -x "$app_bin" ] || return 0
  [ "$dry_run" -eq 0 ] || return 0
  if ! output="$("$app_bin" --unregister-network-helper 2>&1)"; then
    echo "Dory could not unregister its privileged network helper: $output" >&2
    return 1
  fi
  printf '%s\n' "$output" | grep -Fx 'network-helper=disabled' >/dev/null || {
    echo "Dory could not confirm privileged network helper removal." >&2
    return 1
  }
}

csv_append() {
  local list="$1" item="$2"
  [ -n "$list" ] && printf '%s,%s' "$list" "$item" || printf '%s' "$item"
}

install_emit_json() {
  local action="$1" dry_run="$2" path_changed="$3" compose_installed="$4" buildx_installed="$5" linked_csv="$6" missing_csv="$7" context_reconciled="$8" context_removed="$9"
  python3 - "$action" "$dry_run" "$HOME/.dory/bin" "$path_changed" "$compose_installed" "$buildx_installed" "$linked_csv" "$missing_csv" "$context_reconciled" "$context_removed" <<'PY'
import json
import sys

action, dry_run, bin_dir, path_changed, compose_installed, buildx_installed, linked_csv, missing_csv, context_reconciled, context_removed = sys.argv[1:11]
split = lambda value: [item for item in value.split(",") if item]
print(json.dumps({
    "schema": "dev.dory.cli.install",
    "version": 1,
    "action": action,
    "dryRun": dry_run == "1",
    "binDir": bin_dir,
    "linked": split(linked_csv),
    "missing": split(missing_csv),
    "pathProfileChanged": path_changed == "1",
    "composePluginInstalled": compose_installed == "1",
    "buildxPluginInstalled": buildx_installed == "1",
    "dockerContextReconciled": context_reconciled == "1",
    "dockerContextRemoved": context_removed == "1",
}, separators=(",", ":"), sort_keys=True))
PY
}

docker_context_host() {
  local docker="$1"
  "$docker" context inspect dory --format '{{.Endpoints.docker.Host}}' 2>/dev/null \
    | tail -n 1 | tr -d '\r\n'
}

reconcile_docker_context() {
  local docker="$1" dry_run="$2" desired="unix://$DORY_SOCK" existing
  existing="$(docker_context_host "$docker" || true)"
  if [ -n "$existing" ] && [ "$existing" != "$desired" ]; then
    echo "Dory did not replace the existing 'dory' Docker context ($existing)." >&2
    return 1
  fi
  [ -z "$existing" ] || return 0
  if [ "$dry_run" -eq 1 ]; then return 0; fi
  "$docker" context create dory --description Dory --docker "host=$desired" >/dev/null \
    || return 1
  "$docker" context use dory >/dev/null
}

remove_docker_context() {
  local docker="$1" dry_run="$2" desired="unix://$DORY_SOCK" existing current
  existing="$(docker_context_host "$docker" || true)"
  [ "$existing" = "$desired" ] || return 1
  if [ "$dry_run" -eq 1 ]; then return 0; fi
  current="$("$docker" context show 2>/dev/null | tail -n 1 | tr -d '\r\n' || true)"
  if [ "$current" = dory ]; then
    "$docker" context use default >/dev/null || return 1
  fi
  "$docker" context rm -f dory >/dev/null
}

docker_plugin_owned_by_dory() {
  local plugin="$1" destination="$HOME/.docker/cli-plugins/$1" marker="$HOME/.dory/$1-plugin-owned" target recorded=""
  [ -L "$destination" ] || return 1
  target="$(readlink "$destination" 2>/dev/null || true)"
  [ -n "$target" ] || return 1
  [ ! -f "$marker" ] || recorded="$(cat "$marker" 2>/dev/null || true)"
  [ -z "$recorded" ] || [ "$recorded" != "$target" ] || return 0
  case "$target" in
    "$HOME/.dory"/*|"$DORY_SCRIPT_DIR"/*|"$DORY_SCRIPT_DIR/../Helpers"/*) return 0 ;;
    *) return 1 ;;
  esac
}

compose_plugin_owned_by_dory() { docker_plugin_owned_by_dory docker-compose; }

install_cmd() {
  local action="${1:-install}" json=0 dry_run=0
  case "$action" in install|uninstall) shift || true ;; *) install_usage; exit 2 ;; esac
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      --dry-run) dry_run=1; shift ;;
      -h|--help|help) install_usage; return 0 ;;
      *) echo "unknown install option: $1" >&2; install_usage; exit 2 ;;
    esac
  done

  local tools=(docker docker-buildx docker-compose kubectl dory dory-doctor dorydctl)
  local linked_csv="" linked_words="" missing_csv="" tool source dest plugin_dest plugin_marker
  local path_changed=0 compose_installed=0 buildx_installed=0
  local context_reconciled=0 context_removed=0 docker_source=""

  if [ "$action" = "uninstall" ]; then
    remove_dory_launch_agent "$dry_run" || return 1
    unregister_privileged_network_helper "$dry_run" || return 1
    docker_source="$(cli_tool_source docker 2>/dev/null || true)"
    if [ -n "$docker_source" ] && remove_docker_context "$docker_source" "$dry_run"; then
      context_removed=1
    fi
    if remove_path_blocks "$dry_run"; then path_changed=1; fi
    if [ "$dry_run" -eq 0 ]; then
      for tool in "${tools[@]}"; do rm -f "$HOME/.dory/bin/$tool"; done
      for tool in docker-compose docker-buildx; do
        if docker_plugin_owned_by_dory "$tool"; then
          rm -f "$HOME/.docker/cli-plugins/$tool"
        fi
        rm -f "$HOME/.dory/$tool-plugin-owned"
      done
      rm -f "$HOME/.dory/compose-plugin-owned"
    fi
    [ "$json" -eq 1 ] && install_emit_json "$action" "$dry_run" "$path_changed" 0 0 "" "" 0 "$context_removed" || echo "Dory services and shell integration removed; workload data was preserved."
    return 0
  fi

  [ "$dry_run" -eq 1 ] || mkdir -p "$HOME/.dory/bin" "$HOME/.docker/cli-plugins"
  for tool in "${tools[@]}"; do
    source="$(cli_tool_source "$tool" 2>/dev/null || true)"
    if [ -n "$source" ]; then
      linked_csv="$(csv_append "$linked_csv" "$tool")"
      linked_words="$linked_words $tool"
      dest="$HOME/.dory/bin/$tool"
      if [ "$dry_run" -eq 0 ]; then
        if [ "$source" != "$dest" ]; then
          rm -f "$dest"
          ln -s "$source" "$dest"
        fi
      fi
      if [ "$tool" = "docker-compose" ] || [ "$tool" = "docker-buildx" ]; then
        [ "$tool" = "docker-compose" ] && compose_installed=1 || buildx_installed=1
        plugin_dest="$HOME/.docker/cli-plugins/$tool"
        plugin_marker="$HOME/.dory/$tool-plugin-owned"
        if [ "$dry_run" -eq 0 ]; then
          if [ "$source" != "$plugin_dest" ]; then
            if [ ! -e "$plugin_dest" ] && [ ! -L "$plugin_dest" ]; then
              ln -s "$source" "$plugin_dest"
              printf '%s\n' "$source" > "$plugin_marker"
            elif docker_plugin_owned_by_dory "$tool"; then
              rm -f "$plugin_dest"
              ln -s "$source" "$plugin_dest"
              printf '%s\n' "$source" > "$plugin_marker"
            else
              [ "$tool" = "docker-compose" ] && compose_installed=0 || buildx_installed=0
              rm -f "$plugin_marker"
            fi
          fi
        fi
      fi
    else
      missing_csv="$(csv_append "$missing_csv" "$tool")"
    fi
  done
  if install_path_block "$dry_run"; then path_changed=1; fi
  docker_source="$(cli_tool_source docker 2>/dev/null || true)"
  if [ -n "$docker_source" ] && reconcile_docker_context "$docker_source" "$dry_run"; then
    context_reconciled=1
  fi

  if [ "$json" -eq 1 ]; then
    install_emit_json "$action" "$dry_run" "$path_changed" "$compose_installed" "$buildx_installed" "$linked_csv" "$missing_csv" "$context_reconciled" 0
  else
    echo "Dory shell integration installed in $HOME/.dory/bin"
    echo "Open a new terminal, then run: docker version"
    [ -z "$missing_csv" ] || echo "Missing bundled helpers: $missing_csv" >&2
  fi
  case "$linked_words " in *" docker "*) return 0 ;; *) return 1 ;; esac
}

recipe_files() {
  [ -d "$BUILTIN_RECIPE_DIR" ] && find "$BUILTIN_RECIPE_DIR" -maxdepth 1 \( -name '*.yaml' -o -name '*.yml' \) -print
  [ -d "$RECIPE_DIR" ] && find "$RECIPE_DIR" -maxdepth 1 \( -name '*.yaml' -o -name '*.yml' \) -print
}

recipe_field() {
  awk -v key="$1" '
    {
      key_end = index($0, ":")
      if (key_end == 0) next
      name = substr($0, 1, key_end - 1)
      sub(/^[[:space:]]+/, "", name)
      sub(/[[:space:]]+$/, "", name)
      if (name != key) next
      value = substr($0, key_end + 1)
      sub(/^[[:space:]]+/, "", value)
      sub(/[[:space:]]+$/, "", value)
      print value
      exit
    }' "$2"
}

recipe_path() {
  local name="$1" file id
  if [ -f "$name" ]; then echo "$name"; return 0; fi
  while IFS= read -r file; do
    id="$(recipe_field name "$file")"
    [ "$id" = "$name" ] && { echo "$file"; return 0; }
  done < <(recipe_files | sort)
  return 1
}

recipe_ls() {
  local file id summary distro arch source
  printf '%-18s %-14s %-7s %s\n' NAME DISTRO ARCH SUMMARY
  while IFS= read -r file; do
    id="$(recipe_field name "$file")"
    summary="$(recipe_field summary "$file")"
    distro="$(recipe_field distro "$file")"
    arch="$(recipe_field arch "$file")"; [ -n "$arch" ] || arch="$(host_guest_arch)"
    case "$file" in "$RECIPE_DIR"/*) source="user" ;; *) source="built-in" ;; esac
    [ -n "$id" ] && printf '%-18s %-14s %-7s %s [%s]\n' "$id" "$distro" "$arch" "$summary" "$source"
  done < <(recipe_files | sort)
}

recipe_show() {
  local path
  path="$(recipe_path "${1:?usage: dory recipe show <name|path>}")" || { echo "recipe not found: $1" >&2; exit 1; }
  cat "$path"
}

recipe_add() {
  local src="${1:?usage: dory recipe add <url|path>}" tmp name dest
  mkdir -p "$RECIPE_DIR"
  if [[ "$src" =~ ^https?:// ]]; then
    tmp="$(mktemp -t dory-recipe.XXXXXX.yaml)"
    curl -fsSL "$src" -o "$tmp"
  else
    tmp="$src"
  fi
  [ -f "$tmp" ] || { echo "recipe file not found: $src" >&2; exit 1; }
  name="$(recipe_field name "$tmp")"
  [ -n "$name" ] || { echo "recipe is missing top-level name:" >&2; exit 1; }
  # The name becomes a filename under $RECIPE_DIR; reject traversal/separators before writing.
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*$ ]] || { echo "invalid recipe name: $name" >&2; exit 2; }
  dest="$RECIPE_DIR/$name.yaml"
  cp "$tmp" "$dest"
  echo "added recipe $name -> $dest"
}

recipe_new() {
  local name="${1:?usage: dory recipe new <name>}" path
  # The name becomes a filename under $RECIPE_DIR; reject traversal/separators before writing.
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*$ ]] || { echo "invalid recipe name: $name" >&2; exit 2; }
  mkdir -p "$RECIPE_DIR"
  path="$RECIPE_DIR/$name.yaml"
  [ ! -e "$path" ] || { echo "recipe already exists: $path" >&2; exit 1; }
  cat > "$path" <<EOF
name: $name
summary: Custom development environment
distro: ubuntu:24.04
arch: arm64
resources: {cpus: 2, memory: 4GiB, disk: 40GiB}
packages: []
runcmd: []
mounts: []
ports: []
env: {}
ssh: {agent_forward: true}
docker: false
user: {name: "{{host_user}}", sudo: true, shell: /bin/bash}
EOF
  echo "$path"
}

machine_recipe_plan() {
  local recipe="$1" name="$2" out="$3"
  python3 - "$recipe" "$name" "$out" <<'PY'
import json, os, platform, shlex, sys, urllib.parse

recipe_path, machine_name, out_dir = sys.argv[1:4]
host_user = os.environ.get("USER") or os.environ.get("LOGNAME") or "dory"
host_home = os.path.expanduser("~")
host_uid = os.getuid()

def scalar(value):
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in "'\"":
        return value[1:-1]
    if value.lower() == "true":
        return True
    if value.lower() == "false":
        return False
    try:
        return int(value)
    except ValueError:
        return value

def parse_inline(value):
    value = value.strip()
    if value.startswith("[") and value.endswith("]"):
        inner = value[1:-1].strip()
        if not inner:
            return []
        return [scalar(part) for part in inner.split(",")]
    if value.startswith("{") and value.endswith("}"):
        inner = value[1:-1].strip()
        if not inner:
            return {}
        result = {}
        for part in inner.split(","):
            key, raw = part.split(":", 1)
            result[key.strip()] = scalar(raw)
        return result
    return scalar(value)

def load_simple_yaml(path):
    root = {}
    lines = path and open(path, encoding="utf-8").read().splitlines() or []
    i = 0
    while i < len(lines):
        raw = lines[i]
        stripped = raw.strip()
        if not stripped or stripped.startswith("#") or raw.startswith(" "):
            i += 1
            continue
        if ":" not in raw:
            i += 1
            continue
        key, value = raw.split(":", 1)
        key = key.strip()
        value = value.strip()
        if value:
            root[key] = parse_inline(value)
            i += 1
            continue
        items = []
        mapping = {}
        i += 1
        while i < len(lines) and (lines[i].startswith(" ") or not lines[i].strip()):
            child = lines[i].strip()
            if child.startswith("- "):
                items.append(scalar(child[2:]))
            elif child and ":" in child:
                ckey, cvalue = child.split(":", 1)
                mapping[ckey.strip()] = parse_inline(cvalue)
            i += 1
        root[key] = items if items else mapping
    return root

def sub(value, user):
    if isinstance(value, str):
        return value.replace("{{host_user}}", host_user).replace("{{user}}", user)
    if isinstance(value, list):
        return [sub(v, user) for v in value]
    if isinstance(value, dict):
        return {sub(k, user): sub(v, user) for k, v in value.items()}
    return value

catalog = {
    "ubuntu:24.04": ("ubuntu", "Ubuntu", "24.04 LTS", "apt", "systemd"),
    "ubuntu:22.04": ("ubuntu", "Ubuntu", "22.04 LTS", "apt", "systemd"),
    "ubuntu:20.04": ("ubuntu", "Ubuntu", "20.04 LTS", "apt", "systemd"),
    "debian:12": ("debian", "Debian", "12", "apt", "systemd"),
    "debian:11": ("debian", "Debian", "11", "apt", "systemd"),
    "fedora:41": ("fedora", "Fedora", "41", "dnf", "systemd"),
    "fedora:40": ("fedora", "Fedora", "40", "dnf", "systemd"),
    "alpine:3.21": ("alpine", "Alpine", "3.21", "apk", "shell"),
    "alpine:3.20": ("alpine", "Alpine", "3.20", "apk", "shell"),
    "alpine:3.19": ("alpine", "Alpine", "3.19", "apk", "shell"),
    "archlinux:latest": ("arch", "Arch Linux", "Rolling", "pacman", "systemd"),
}

recipe = load_simple_yaml(recipe_path)
recipe_id = str(recipe.get("name") or "").strip()
if not recipe_id:
    raise SystemExit("recipe is missing top-level name:")
user_cfg = recipe.get("user") or {}
guest_user_template = str(user_cfg.get("name", "{{host_user}}"))
guest_user = sub(guest_user_template, guest_user_template.replace("{{host_user}}", host_user))
recipe = sub(recipe, guest_user)
distro = str(recipe.get("distro") or "ubuntu:24.04")
arch = str(recipe.get("arch") or ("amd64" if platform.machine() == "x86_64" else "arm64"))
resources = recipe.get("resources") or {}
packages = recipe.get("packages") or []
runcmd = recipe.get("runcmd") or []
mounts = recipe.get("mounts") or []
ports = [int(p) for p in (recipe.get("ports") or [])]
env = recipe.get("env") or {}
docker_enabled = bool(recipe.get("docker", False))
user_cfg = recipe.get("user") or {}
guest_user = str(user_cfg.get("name") or host_user)
guest_shell = str(user_cfg.get("shell") or "/bin/bash")
if distro not in catalog:
    raise SystemExit(f"unsupported recipe distro {distro}")
if arch not in ("arm64", "amd64"):
    raise SystemExit(f"unsupported recipe arch {arch}")
family, display, version, pkg, boot = catalog[distro]
base_tag = f"dory-machine/{distro}-{arch}-v2"
recipe_tag = f"dory-recipe/{recipe_id}-{arch}"
container = f"dory-machine-{machine_name}"
platform = f"linux/{arch}"

def size_mb(value):
    text = str(value)
    for suffix, mult in (("TiB", 1024 * 1024), ("GiB", 1024), ("MiB", 1)):
        if text.endswith(suffix):
            return int(text[:-len(suffix)]) * mult
    return None

def quote(value):
    return shlex.quote(str(value))

def package_install(names):
    if not names:
        return ""
    joined = " ".join(quote(n) for n in names)
    if pkg == "apt":
        return f"apt-get update -qq && apt-get install -y --no-install-recommends {joined} && rm -rf /var/lib/apt/lists/*"
    if pkg == "dnf":
        return f"dnf install -y {joined} && dnf clean all"
    if pkg == "apk":
        return f"apk add --no-cache {joined}"
    if pkg == "pacman":
        return f"pacman -Sy --noconfirm --needed {joined}"
    return ""

def base_dockerfile():
    if pkg == "apt":
        return f"""FROM {distro}
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update \\
 && apt-get install -y --no-install-recommends systemd systemd-sysv dbus dbus-user-session sudo bash openssh-server netcat-openbsd ca-certificates iproute2 iputils-ping curl \\
 && rm -rf /var/lib/apt/lists/* \\
 && (systemctl mask systemd-resolved.service systemd-networkd.service || true)
STOPSIGNAL SIGRTMIN+3
CMD ["/sbin/init"]
"""
    if pkg == "dnf":
        return f"""FROM {distro}
RUN dnf -y install systemd sudo passwd iproute procps-ng openssh-server nmap-ncat \\
 && dnf clean all \\
 && (systemctl mask systemd-resolved.service || true)
STOPSIGNAL SIGRTMIN+3
CMD ["/sbin/init"]
"""
    if pkg == "apk":
        return f"""FROM {distro}
RUN apk add --no-cache bash sudo shadow iproute2 ca-certificates openssh netcat-openbsd
CMD ["tail", "-f", "/dev/null"]
"""
    if pkg == "pacman":
        return f"""FROM {distro}
RUN pacman -Sy --noconfirm --disable-sandbox --needed sudo iproute2 openssh gnu-netcat \\
 && (pacman -Scc --noconfirm --disable-sandbox || true)
STOPSIGNAL SIGRTMIN+3
CMD ["/sbin/init"]
"""
    raise SystemExit(f"unsupported package manager {pkg}")

provision = [package_install(packages), *[str(c) for c in runcmd]]
if docker_enabled:
    provision.append("install -d -m 755 /var/run/dory")
provision_script = "\n".join(line for line in provision if line.strip())
recipe_dockerfile = f"""FROM {base_tag}
RUN <<'DORY_RECIPE'
set -e
{provision_script}
DORY_RECIPE
"""

host_config = {
    "Privileged": True,
    "CgroupnsMode": "host",
    "Tmpfs": {"/run": "", "/run/lock": "", "/tmp": ""},
    "RestartPolicy": {"Name": "unless-stopped"},
}
cpus = int(resources.get("cpus") or 0)
memory = size_mb(resources.get("memory") or "")
if cpus > 0:
    host_config["NanoCpus"] = cpus * 1000000000
if memory:
    host_config["Memory"] = memory * 1024 * 1024
binds = []
for mount in mounts:
    parts = str(mount).split(":")
    if len(parts) >= 2:
        host = os.path.expanduser(parts[0])
        guest = parts[1].replace("~", f"/home/{guest_user}", 1) if parts[1].startswith("~") else parts[1]
        suffix = ":ro" if len(parts) >= 3 and parts[2] == "ro" else ""
        binds.append(f"{host}:{guest}{suffix}")
bridge = os.path.join(host_home, ".dory", "bridge", machine_name)
binds.append(f"{bridge}:/opt/dory/bridge")
host_config["Binds"] = binds
if ports:
    host_config["PortBindings"] = {f"{p}/tcp": [{"HostPort": str(p)}] for p in ports}

labels = {
    "dory.machine": family,
    "dory.machine.version": version,
    "dory.machine.arch": arch,
    "dory.recipe": recipe_id,
}
if guest_user != "root":
    guest_home = host_home if guest_user == host_user else f"/home/{guest_user}"
    labels.update({
        "dory.machine.user": guest_user,
        "dory.machine.uid": str(host_uid if guest_user == host_user else 1000),
        "dory.machine.home": guest_home,
        "dory.machine.shell": guest_shell,
    })
if 22 in ports:
    labels["dory.machine.sshPort"] = "22"
body = {
    "Hostname": machine_name,
    "Image": recipe_tag,
    "Cmd": ["/sbin/init"] if boot == "systemd" else ["tail", "-f", "/dev/null"],
    "Env": sorted([
        "BROWSER=dory-open",
        "container=docker",
        "SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock",
        "GIT_ASKPASS=/usr/local/bin/dory-git-askpass",
        "DORY_GIT_ASKPASS_SOCK=/opt/dory/bridge/credentials/git-askpass.sock",
        *[f"{k}={v}" for k, v in env.items()],
    ]),
    "StopSignal": "SIGRTMIN+3",
    "Labels": labels,
    "HostConfig": host_config,
}
if ports:
    body["ExposedPorts"] = {f"{p}/tcp": {} for p in ports}

os.makedirs(out_dir, exist_ok=True)
open(os.path.join(out_dir, "base.Dockerfile"), "w", encoding="utf-8").write(base_dockerfile())
open(os.path.join(out_dir, "recipe.Dockerfile"), "w", encoding="utf-8").write(recipe_dockerfile)
open(os.path.join(out_dir, "create.json"), "w", encoding="utf-8").write(json.dumps(body, indent=2, sort_keys=True) + "\n")
create_path = "/containers/create?name=" + urllib.parse.quote(container, safe="") + "&platform=" + urllib.parse.quote(platform, safe="")
start_path = "/containers/" + urllib.parse.quote(container, safe="") + "/start"
env_path = os.path.join(out_dir, "plan.env")
with open(env_path, "w", encoding="utf-8") as f:
    for key, value in {
        "RECIPE_ID": recipe_id,
        "DISTRO": distro,
        "ARCH": arch,
        "PLATFORM": platform,
        "BASE_TAG": base_tag,
        "RECIPE_TAG": recipe_tag,
        "CONTAINER_NAME": container,
        "BRIDGE_DIR": bridge,
        "CREATE_PATH": create_path,
        "START_PATH": start_path,
    }.items():
        f.write(f"{key}={quote(value)}\n")
PY
}

machine_create_recipe() {
  local name="" recipe="" dry_run=0 tmp
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --recipe) recipe="${2:?usage: dory machine create <name> --recipe <name|path> [--dry-run]}"; shift 2 ;;
      --dry-run) dry_run=1; shift ;;
      --*) echo "unknown machine create option: $1" >&2; exit 2 ;;
      *) if [ -z "$name" ]; then name="$1"; shift; else echo "unexpected argument: $1" >&2; exit 2; fi ;;
    esac
  done
  [ -n "$name" ] && [ -n "$recipe" ] || { echo "usage: dory machine create <name> --recipe <name|path> [--dry-run]" >&2; exit 2; }
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*$ ]] || { echo "invalid machine name: $name" >&2; exit 2; }
  recipe="$(recipe_path "$recipe")" || { echo "recipe not found: $recipe" >&2; exit 1; }
  tmp="$(mktemp -d -t dory-machine-recipe.XXXXXX)"
  machine_recipe_plan "$recipe" "$name" "$tmp"
  # shellcheck disable=SC1091
  source "$tmp/plan.env"
  if [ "$dry_run" -eq 1 ]; then
    echo "recipe: $RECIPE_ID"
    echo "base image: $BASE_TAG"
    echo "recipe image: $RECIPE_TAG"
    echo "container: $CONTAINER_NAME"
    echo "create path: $CREATE_PATH"
    echo "start path: $START_PATH"
    echo "--- create.json ---"
    sed -n '1,220p' "$tmp/create.json"
    echo "--- recipe.Dockerfile ---"
    sed -n '1,220p' "$tmp/recipe.Dockerfile"
    return 0
  fi
  mkdir -p "$BRIDGE_DIR"
  if ! "$DOCKER_BIN" -H "unix://$DORY_SOCK" image inspect "$BASE_TAG" >/dev/null 2>&1; then
    "$DOCKER_BIN" -H "unix://$DORY_SOCK" build --platform "$PLATFORM" -t "$BASE_TAG" -f "$tmp/base.Dockerfile" "$tmp"
  fi
  if ! "$DOCKER_BIN" -H "unix://$DORY_SOCK" image inspect "$RECIPE_TAG" >/dev/null 2>&1; then
    "$DOCKER_BIN" -H "unix://$DORY_SOCK" build --platform "$PLATFORM" -t "$RECIPE_TAG" -f "$tmp/recipe.Dockerfile" "$tmp"
  fi
  curl --unix-socket "$DORY_SOCK" -fsS -X POST -H 'Content-Type: application/json' \
    --data-binary @"$tmp/create.json" "http://dory$CREATE_PATH" >/dev/null
  curl --unix-socket "$DORY_SOCK" -fsS -X POST "http://dory$START_PATH" >/dev/null
  echo "created machine $name from recipe $RECIPE_ID"
}

dory_urlencode() {
  python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=""))' "$1"
}

machine_container_name() {
  printf 'dory-machine-%s' "$1"
}

machine_snapshot_ref() {
  local machine="$1" selector="$2"
  if [[ "$selector" == sha256:* || "$selector" == *"/"* || "$selector" == *":"* ]]; then
    printf '%s' "$selector"
  else
    printf 'dory-snapshot/%s:%s' "$machine" "$selector"
  fi
}

machine_snapshot_create() {
  local name="${1:?usage: dory machine snapshot <name> [--note text] [--tag tag]}" note="" tag="" cid labels body repo path id
  shift
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --note) note="${2:?--note requires text}"; shift 2 ;;
      --tag) tag="${2:?--tag requires tag}"; shift 2 ;;
      --*) echo "unknown snapshot option: $1" >&2; exit 2 ;;
      *) note="$1"; shift ;;
    esac
  done
  cid="$(machine_container_name "$name")"
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" inspect "$cid" >/dev/null
  [ -n "$tag" ] || tag="s$(date -u +%s)"
  repo="dory-snapshot/$name"
  labels="$("$DOCKER_BIN" -H "unix://$DORY_SOCK" inspect -f '{{json .Config.Labels}}' "$cid")"
  body="$(mktemp -t dory-snapshot.XXXXXX.json)"
  python3 - "$labels" "$name" "$note" "$(date -u +%Y-%m-%dT%H:%M:%SZ)" > "$body" <<'PY'
import json, sys

labels = json.loads(sys.argv[1] or "{}")
machine, note, created = sys.argv[2:5]
out = {}
for key in ("dory.machine", "dory.machine.version", "dory.machine.arch", "dory.machine.boot",
            "dory.recipe", "dory.machine.user", "dory.machine.uid", "dory.machine.home",
            "dory.machine.shell", "dory.machine.sshPort"):
    if labels.get(key):
        out[key] = labels[key]
out.setdefault("dory.machine.boot", "systemd")
out["dory.snapshot.of"] = machine
out["dory.snapshot.note"] = note
out["dory.snapshot.created"] = created
print(json.dumps({"Labels": out}, separators=(",", ":")))
PY
  path="/commit?container=$(dory_urlencode "$cid")&repo=$(dory_urlencode "$repo")&tag=$(dory_urlencode "$tag")"
  id="$(curl --unix-socket "$DORY_SOCK" -fsS -X POST -H 'Content-Type: application/json' --data-binary @"$body" "http://dory$path" \
    | python3 -c 'import json,sys; print(json.load(sys.stdin).get("Id",""))')"
  rm -f "$body"
  echo "snapshot $repo:$tag ${id:+($id)}"
}

machine_snapshot_list() {
  local machine="${1:-}" filter ids inspect
  filter="label=dory.snapshot.of"
  [ -z "$machine" ] || filter="label=dory.snapshot.of=$machine"
  ids="$("$DOCKER_BIN" -H "unix://$DORY_SOCK" image ls -q --filter "$filter" | sort -u)"
  printf '%-32s %-20s %-19s %s\n' IMAGE MACHINE CREATED NOTE
  [ -n "$ids" ] || return 0
  inspect="$(mktemp -t dory-snapshots.XXXXXX.json)"
  # shellcheck disable=SC2086
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" image inspect $ids > "$inspect"
  python3 - "$inspect" <<'PY'
import json, sys

for image in json.load(open(sys.argv[1])):
    labels = image.get("Config", {}).get("Labels") or {}
    tags = [t for t in image.get("RepoTags") or [] if t != "<none>:<none>"]
    ref = tags[0] if tags else image.get("Id", "")
    print(f"{ref[:31]:<32} {labels.get('dory.snapshot.of','')[:19]:<20} {labels.get('dory.snapshot.created','')[:19]:<19} {labels.get('dory.snapshot.note','')}")
PY
  rm -f "$inspect"
}

machine_snapshot_create_body() {
  local image="$1" name="$2" out="$3" bridge="$4" inspect
  inspect="$(mktemp -t dory-snapshot-image.XXXXXX.json)"
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" image inspect "$image" > "$inspect"
  python3 - "$inspect" "$image" "$name" "$bridge" > "$out" <<'PY'
import json, sys

inspect_path, image_ref, name, bridge = sys.argv[1:5]
image = json.load(open(inspect_path))[0]
labels = image.get("Config", {}).get("Labels") or {}
boot = labels.get("dory.machine.boot", "systemd")
arch = labels.get("dory.machine.arch", "amd64" if __import__("platform").machine() == "x86_64" else "arm64")
container_labels = {
    "dory.machine": labels.get("dory.machine", labels.get("dory.snapshot.of", name)),
    "dory.machine.version": labels.get("dory.machine.version", ""),
    "dory.machine.arch": arch,
    "dory.machine.boot": boot,
}
for key in ("dory.recipe", "dory.machine.user", "dory.machine.uid", "dory.machine.home", "dory.machine.shell", "dory.machine.sshPort"):
    if labels.get(key):
        container_labels[key] = labels[key]
cmd = ["/sbin/init"] if boot == "systemd" else ["tail", "-f", "/dev/null"]
body = {
    "Hostname": name,
    "Image": image_ref,
    "Cmd": cmd,
    "Env": [
        "BROWSER=dory-open",
        "container=docker",
        "SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock",
        "GIT_ASKPASS=/usr/local/bin/dory-git-askpass",
        "DORY_GIT_ASKPASS_SOCK=/opt/dory/bridge/credentials/git-askpass.sock",
    ],
    "StopSignal": "SIGRTMIN+3",
    "Labels": container_labels,
    "HostConfig": {
        "Privileged": True,
        "CgroupnsMode": "host",
        "Tmpfs": {"/run": "", "/run/lock": "", "/tmp": ""},
        "RestartPolicy": {"Name": "unless-stopped"},
        "Binds": [f"{bridge}:/opt/dory/bridge"],
    },
}
print(json.dumps({"platform": f"linux/{arch}", "body": body}, separators=(",", ":")))
PY
  rm -f "$inspect"
}

machine_run_snapshot_image() {
  local name="$1" image="$2" cid bridge tmp platform create_path
  cid="$(machine_container_name "$name")"
  bridge="$HOME/.dory/bridge/$name"
  mkdir -p "$bridge"
  tmp="$(mktemp -t dory-machine-restore.XXXXXX.json)"
  machine_snapshot_create_body "$image" "$name" "$tmp" "$bridge"
  platform="$(python3 -c 'import json,sys; print(json.load(open(sys.argv[1]))["platform"])' "$tmp")"
  python3 -c 'import json,sys; print(json.dumps(json.load(open(sys.argv[1]))["body"]))' "$tmp" > "$tmp.body"
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" rm -f "$cid" >/dev/null 2>&1 || true
  create_path="/containers/create?name=$(dory_urlencode "$cid")&platform=$(dory_urlencode "$platform")"
  curl --unix-socket "$DORY_SOCK" -fsS -X POST -H 'Content-Type: application/json' --data-binary @"$tmp.body" "http://dory$create_path" >/dev/null
  curl --unix-socket "$DORY_SOCK" -fsS -X POST "http://dory/containers/$(dory_urlencode "$cid")/start" >/dev/null
  rm -f "$tmp" "$tmp.body"
  echo "started $name from $image"
}

machine_snapshot_restore() {
  local name="${1:?usage: dory machine restore <name> <tag|image>}" selector="${2:?usage: dory machine restore <name> <tag|image>}" image
  image="$(machine_snapshot_ref "$name" "$selector")"
  machine_run_snapshot_image "$name" "$image"
}

machine_snapshot_clone() {
  local source="${1:?usage: dory machine clone <source-machine> <tag|image> <new-name>}" selector="${2:?usage: dory machine clone <source-machine> <tag|image> <new-name>}" name="${3:?usage: dory machine clone <source-machine> <tag|image> <new-name>}" image
  image="$(machine_snapshot_ref "$source" "$selector")"
  machine_run_snapshot_image "$name" "$image"
}

machine_snapshot_export() {
  local image dest
  if [ "$#" -eq 3 ]; then
    image="$(machine_snapshot_ref "$1" "$2")"
    dest="$3"
  else
    image="${1:?usage: dory machine export [machine] <tag|image> <file>}"
    dest="${2:?usage: dory machine export [machine] <tag|image> <file>}"
  fi
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" save -o "$dest" "$image"
  echo "$dest"
}

machine_snapshot_backup() {
  local image dest tmp filename
  if [ "$#" -eq 3 ]; then
    image="$(machine_snapshot_ref "$1" "$2")"
    dest="$3"
  else
    image="${1:?usage: dory machine backup [machine] <tag|image> <s3://bucket/prefix-or-file>}"
    dest="${2:?usage: dory machine backup [machine] <tag|image> <s3://bucket/prefix-or-file>}"
  fi
  command -v aws >/dev/null 2>&1 || { echo "aws CLI not found; install and configure aws first" >&2; exit 1; }
  case "$dest" in s3://*) ;; *) echo "backup destination must be s3://bucket/key-or-prefix" >&2; exit 2 ;; esac
  filename="$(printf '%s' "$image" | sed 's#[/:]#-#g' | tr -cd '[:alnum:]_.-').tar"
  case "$dest" in
    */) dest="$dest$filename" ;;
  esac
  tmp="$(mktemp -t dory-machine-backup.XXXXXX.tar)"
  trap 'rm -f "$tmp"' RETURN
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" save -o "$tmp" "$image"
  aws s3 cp "$tmp" "$dest"
  echo "$dest"
}

machine_snapshot_import() {
  local src="${1:?usage: dory machine import <file>}"
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" load -i "$src"
}

machine_snapshot_delete() {
  local image
  if [ "$#" -eq 2 ]; then
    image="$(machine_snapshot_ref "$1" "$2")"
  else
    image="${1:?usage: dory machine delete-snapshot [machine] <tag|image>}"
  fi
  "$DOCKER_BIN" -H "unix://$DORY_SOCK" rmi "$image"
}

dorydctl_bin() {
  first_executable \
    "${DORYDCTL_BIN:-}" \
    "$DORY_SCRIPT_DIR/dorydctl" \
    "$DORY_SCRIPT_DIR/../Helpers/dorydctl" \
    "$HOME/.dory/bin/dorydctl" \
    "$(command -v dorydctl 2>/dev/null || true)"
}

installed_component_asset() {
  local component="$1" asset="$2" ctl
  ctl="$(dorydctl_bin 2>/dev/null)" || return 1
  "$ctl" component path "$component" "$asset" 2>/dev/null
}

network_helper_bin() {
  first_executable \
    "${DORY_NETWORK_HELPER_BIN:-}" \
    "$DORY_SCRIPT_DIR/dory-network-helper" \
    "$DORY_SCRIPT_DIR/../Helpers/dory-network-helper" \
    "$HOME/.dory/bin/dory-network-helper" \
    "$(command -v dory-network-helper 2>/dev/null || true)"
}

network_authorization_usage() {
  cat >&2 <<'EOF'
usage:
  dory network authorization-plan [--json]
  dory network authorize [--json] [--dry-run|--apply] [--plan-json PATH] [--file-system-root PATH]
  dory network deauthorize [--json] [--dry-run|--apply] [--plan-json PATH] [--file-system-root PATH]

Both mutations default to --dry-run. Authorize --apply installs Dory's resolver, owned pf
reference, and local CA trust. Deauthorize --apply removes that exact owned integration.
Applying requires admin privileges; use Settings for the guided macOS prompt, or run from root.
EOF
}

network_plan_text() {
  python3 -c '
import json, sys
plan = json.load(sys.stdin)
print(f"Domain suffix: {plan.get(\"suffix\", \"unknown\")}")
print(f"Mode: {plan.get(\"degradedMode\", \"unknown\")} -> {plan.get(\"authorizedMode\", \"unknown\")}")
print(f"Resolver: {plan.get(\"dnsBindAddress\", \"127.0.0.1\")}:{plan.get(\"dnsPort\", \"?\")}")
print(f"HTTP/HTTPS: 80->{plan.get(\"httpProxyPort\", \"?\")} 443->{plan.get(\"httpsProxyPort\", \"?\")}")
for forward in plan.get("privilegedTCPForwards") or []:
    print(f"Low TCP: {forward.get(\"listenPort\")}->{forward.get(\"targetPort\")}")
print("Requests:")
for request in plan.get("requests") or []:
    command = " ".join(request.get("command") or [])
    print(f"  - {request.get(\"kind\", \"unknown\")}: {request.get(\"title\", request.get(\"id\", \"?\"))} [{command}]")
'
}

network_authorize_json() {
  local plan_path="$1" dry_run="$2" results_path="$3" operation="$4"
  python3 - "$plan_path" "$dry_run" "$results_path" "$operation" <<'PY'
import json
import sys

plan_path = sys.argv[1]
dry_run = sys.argv[2] == "1"
results_path = sys.argv[3]
operation = sys.argv[4]
plan = json.load(open(plan_path, encoding="utf-8"))
results = json.load(open(results_path, encoding="utf-8"))
print(json.dumps({
    "schema": "dev.dory.network.authorization",
    "version": 1,
    "dryRun": dry_run,
    "applied": not dry_run,
    "operation": operation,
    "suffix": plan.get("suffix"),
    "degradedMode": plan.get("degradedMode"),
    "authorizedMode": plan.get("authorizedMode"),
    "privilegedTCPForwards": plan.get("privilegedTCPForwards") or [],
    "results": results,
}, separators=(",", ":"), sort_keys=True))
PY
}

network_authorize_text() {
  local plan_path="$1" dry_run="$2" results_path="$3" operation="$4"
  python3 - "$plan_path" "$dry_run" "$results_path" "$operation" <<'PY'
import json
import sys

plan_path = sys.argv[1]
dry_run = sys.argv[2] == "1"
results_path = sys.argv[3]
operation = sys.argv[4]
plan = json.load(open(plan_path, encoding="utf-8"))
results = json.load(open(results_path, encoding="utf-8"))
mode = "dry-run" if dry_run else "applied"
print(f"Dory networking {operation} {mode} for {plan.get('suffix', 'unknown')}:")
for item in results:
    print(f"  - {item.get('action', '?')} {item.get('target', '?')}")
forwards = plan.get("privilegedTCPForwards") or []
if forwards:
    shown = ", ".join(f"{item.get('listenPort')}->{item.get('targetPort')}" for item in forwards[:6])
    extra = len(forwards) - 6
    print("Low TCP forwards: " + shown + (f", +{extra} more" if extra > 0 else ""))
else:
    print("Low TCP forwards: standard 80/443 only")
PY
}

network_authorization_plan_cmd() {
  local json=0 ctl out
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) network_authorization_usage; return 0 ;;
      *) echo "unknown network authorization-plan option: $1" >&2; network_authorization_usage; exit 2 ;;
    esac
  done
  ctl="$(dorydctl_bin 2>/dev/null)" || { echo "dorydctl not found; start Dory/doryd before inspecting networking authorization." >&2; exit 1; }
  out="$("$ctl" --timeout 10 network authorization-plan)"
  if [ "$json" -eq 1 ]; then
    printf '%s\n' "$out"
  else
    printf '%s\n' "$out" | network_plan_text
  fi
}

network_authorize_cmd() {
  local operation="${1:?network authorization operation required}"
  shift
  local json=0 dry_run=1 apply=0 plan_path="" fs_root="" helper ctl tmp="" results_tmp="" out rc args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      --dry-run) dry_run=1; apply=0; shift ;;
      --apply) dry_run=0; apply=1; shift ;;
      --plan-json|--plan) plan_path="${2:?$1 requires a path}"; shift 2 ;;
      --file-system-root) fs_root="${2:?--file-system-root requires a path}"; shift 2 ;;
      -h|--help) network_authorization_usage; return 0 ;;
      *) echo "unknown network authorize option: $1" >&2; network_authorization_usage; exit 2 ;;
    esac
  done

  helper="$(network_helper_bin 2>/dev/null)" || { echo "dory-network-helper not found; reinstall Dory or run dory support bundle for diagnostics." >&2; exit 1; }
  if [ -z "$plan_path" ]; then
    ctl="$(dorydctl_bin 2>/dev/null)" || { echo "dorydctl not found; start Dory/doryd before authorizing networking." >&2; exit 1; }
    tmp="$(mktemp -t dory-network-plan.XXXXXX.json)"
    "$ctl" --timeout 10 network authorization-plan > "$tmp"
    plan_path="$tmp"
  fi

  if [ "$apply" -eq 1 ] && [ "$(id -u)" -ne 0 ]; then
    [ -z "$tmp" ] || rm -f "$tmp"
    echo "dory network $operation --apply needs admin privileges. Use Dory Settings > Network, or rerun from root." >&2
    exit 1
  fi

  args=(--plan-json "$plan_path")
  [ "$dry_run" -eq 1 ] && args+=(--dry-run)
  args+=(--owner-uid "${SUDO_UID:-$(id -u)}")
  [ "$operation" = "deauthorize" ] && args+=(--remove)
  [ -n "$fs_root" ] && args+=(--file-system-root "$fs_root")
  set +e
  out="$("$helper" "${args[@]}" 2>&1)"
  rc=$?
  set -e
  if [ "$rc" -ne 0 ]; then
    [ -z "$tmp" ] || rm -f "$tmp"
    printf '%s\n' "$out" >&2
    exit "$rc"
  fi
  results_tmp="$(mktemp -t dory-network-results.XXXXXX.json)"
  printf '%s\n' "$out" > "$results_tmp"
  if [ "$json" -eq 1 ]; then
    network_authorize_json "$plan_path" "$dry_run" "$results_tmp" "$operation"
  else
    network_authorize_text "$plan_path" "$dry_run" "$results_tmp" "$operation"
  fi
  rm -f "$results_tmp"
  [ -z "$tmp" ] || rm -f "$tmp"
}

network_cmd() {
  case "${1:-}" in
    authorization-plan|auth-plan) shift || true; network_authorization_plan_cmd "$@" ;;
    authorize) shift || true; network_authorize_cmd authorize "$@" ;;
    deauthorize) shift || true; network_authorize_cmd deauthorize "$@" ;;
    custom-domains|set-custom-domain|remove-custom-domain|corporate)
      local subcommand="$1" ctl
      shift || true
      ctl="$(dorydctl_bin 2>/dev/null)" || { echo "dorydctl not found; start Dory before managing custom domains." >&2; exit 1; }
      "$ctl" --timeout 10 network "$subcommand" "$@"
      ;;
    -h|--help) doctor_cmd network --help ;;
    *) doctor_cmd network "$@" ;;
  esac
}

dory_machine_has_option() {
  local option="$1" arg
  shift
  while [ "$#" -gt 0 ]; do
    arg="${1:-}"
    case "$arg" in
      "$option"|"$option"=*) return 0 ;;
    esac
    shift
  done
  return 1
}

dory_machine_option_value() {
  local option="$1" arg
  shift
  while [ "$#" -gt 0 ]; do
    arg="${1:-}"
    case "$arg" in
      "$option") [ "$#" -ge 2 ] || return 2; printf '%s\n' "$2"; return 0 ;;
      "$option"=*) printf '%s\n' "${arg#*=}"; return 0 ;;
    esac
    shift
  done
  return 1
}

verify_dory_machine_image_manifest() {
  local manifest="$1" signature="$2" allowed_signers="$3" signer="$4" kernel="$5" rootfs="$6"
  local expected kernel_expected rootfs_expected kernel_actual rootfs_actual
  for file in "$manifest" "$signature" "$allowed_signers" "$kernel" "$rootfs"; do
    [ -f "$file" ] || { echo "machine image verification input not found: $file" >&2; return 1; }
  done
  command -v ssh-keygen >/dev/null || { echo "ssh-keygen is required for signed machine images" >&2; return 1; }
  command -v shasum >/dev/null || { echo "shasum is required for signed machine images" >&2; return 1; }
  if ! ssh-keygen -Y verify -f "$allowed_signers" -I "$signer" -n dory-machine-image \
      -s "$signature" < "$manifest" >/dev/null; then
    echo "machine image manifest signature is invalid for signer $signer" >&2
    return 1
  fi
  expected="$(python3 - "$manifest" <<'PY'
import json, re, sys
data = json.load(open(sys.argv[1], encoding="utf-8"))
if data.get("schema") != "dev.dory.machine-image" or data.get("version") != 1:
    raise SystemExit("unsupported machine image manifest schema/version")
values = []
for key in ("kernel", "rootfs"):
    value = (data.get(key) or {}).get("sha256", "").lower()
    if not re.fullmatch(r"[0-9a-f]{64}", value):
        raise SystemExit(f"invalid {key}.sha256 in machine image manifest")
    values.append(value)
print("\t".join(values))
PY
  )" || return 1
  kernel_expected="${expected%%$'\t'*}"
  rootfs_expected="${expected#*$'\t'}"
  kernel_actual="$(shasum -a 256 "$kernel" | awk '{print $1}')"
  rootfs_actual="$(shasum -a 256 "$rootfs" | awk '{print $1}')"
  [ "$kernel_actual" = "$kernel_expected" ] || {
    echo "machine kernel digest does not match signed manifest" >&2
    return 1
  }
  [ "$rootfs_actual" = "$rootfs_expected" ] || {
    echo "machine rootfs digest does not match signed manifest" >&2
    return 1
  }
}

dory_machine_env_allow_list() {
  local raw
  if [ "${DORY_MACHINE_ENV_ALLOW_LIST+x}" = "x" ]; then
    printf '%s\n' "$DORY_MACHINE_ENV_ALLOW_LIST"
    return 0
  fi
  if raw="$(defaults read com.pythonxi.Dory dory.machineEnvAllowList 2>/dev/null)"; then
    printf '%s\n' "$raw"
  else
    printf '%s\n' "ANTHROPIC_API_KEY"
  fi
}

dory_machine_env_rows() {
  local raw token key value seen=" "
  raw="$(dory_machine_env_allow_list)"
  for token in $(printf '%s\n' "$raw" | tr ',\n\t' '   '); do
    key="$(printf '%s' "$token" | tr '[:lower:]' '[:upper:]')"
    [[ "$key" =~ ^[A-Z_][A-Z0-9_]*$ ]] || continue
    case "$seen" in *" $key "*) continue ;; esac
    seen="$seen$key "
    value="${!key-}"
    [ -n "$value" ] || continue
    printf '%s=%s\n' "$key" "$value"
  done
}

DORY_CONFIRM_REMAINDER=()

require_exact_confirmation() {
  local action="$1" expected="$2" confirmed=""
  shift 2
  DORY_CONFIRM_REMAINDER=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --confirm)
        [ -z "$confirmed" ] || { echo "$action accepts exactly one --confirm value" >&2; return 2; }
        confirmed="${2:?$action requires --confirm $expected}"
        shift 2
        ;;
      --confirm=*)
        echo "$action requires a separate exact confirmation: --confirm $expected" >&2
        return 2
        ;;
      *) DORY_CONFIRM_REMAINDER+=("$1"); shift ;;
    esac
  done
  if [ "$confirmed" != "$expected" ]; then
    echo "$action changes or permanently removes '$expected'. Re-run with --confirm '$expected'." >&2
    return 2
  fi
}

component_cmd() {
  local ctl sub id
  ctl="$(dorydctl_bin 2>/dev/null)" || { echo "dorydctl not found; reinstall Dory Docker Core" >&2; return 1; }
  sub="${1:-list}"
  if [ "$sub" != "remove" ]; then
    exec "$ctl" component "$@"
  fi
  shift
  id="${1:?usage: dory component remove ID --confirm ID [--json] [--offline]}"
  shift
  require_exact_confirmation "component removal" "$id" "$@" || return $?
  exec "$ctl" component remove "$id" "${DORY_CONFIRM_REMAINDER[@]}"
}

doryd_machine_cmd() {
  local ctl="$1" sub name args=()
  shift
  sub="${1:-list}"
  case "$sub" in
    ls|list)
      exec "$ctl" machine list
      ;;
    run|exec)
      shift
      name="${1:?usage: dory machine run <name> -- <command...>}"
      shift
      args=("$name")
      while [ "$#" -gt 0 ] && [ "${1:-}" != "--" ]; do
        args+=("$1")
        shift
      done
      [ "${1:-}" != "--" ] || shift
      [ "$#" -gt 0 ] || { echo "usage: dory machine run <name> -- <command...>" >&2; exit 2; }
      args+=(--)
      exec "$ctl" machine exec "${args[@]}" "$@"
      ;;
    ssh|shell)
      shift
      name="${1:?usage: dory machine shell <name>}"
      exec "$ctl" machine shell "$name"
      ;;
    clone)
      shift
      exec "$ctl" machine clone-snapshot "$@"
      ;;
    restore)
      shift
      name="${1:?usage: dory machine restore NAME SNAPSHOT_ID --confirm NAME}"
      local snapshot_id="${2:?usage: dory machine restore NAME SNAPSHOT_ID --confirm NAME}" safety_json safety_id
      shift 2
      require_exact_confirmation "machine restore" "$name" "$@" || return $?
      [ "${#DORY_CONFIRM_REMAINDER[@]}" -eq 0 ] || {
        echo "unexpected machine restore argument: ${DORY_CONFIRM_REMAINDER[0]}" >&2
        return 2
      }
      safety_json="$("$ctl" machine snapshot "$name" --note "Automatic pre-restore safety snapshot")" || return $?
      safety_id="$(python3 -c 'import json,sys; value=json.load(sys.stdin).get("id", ""); print(value); raise SystemExit(0 if value else 1)' <<<"$safety_json")" || {
        echo "Dory created a safety snapshot but could not verify its ID; restore was not attempted." >&2
        return 1
      }
      echo "Created retained pre-restore safety snapshot: $safety_id" >&2
      exec "$ctl" machine restore-snapshot "$name" "$snapshot_id"
      ;;
    export)
      shift
      exec "$ctl" machine export-snapshot "$@"
      ;;
    import)
      shift
      exec "$ctl" machine import-snapshot "$@"
      ;;
    delete-snapshot|rm-snapshot)
      shift
      name="${1:?usage: dory machine delete-snapshot NAME SNAPSHOT_ID --confirm SNAPSHOT_ID}"
      local delete_snapshot_id="${2:?usage: dory machine delete-snapshot NAME SNAPSHOT_ID --confirm SNAPSHOT_ID}"
      shift 2
      require_exact_confirmation "snapshot deletion" "$delete_snapshot_id" "$@" || return $?
      [ "${#DORY_CONFIRM_REMAINDER[@]}" -eq 0 ] || {
        echo "unexpected snapshot deletion argument: ${DORY_CONFIRM_REMAINDER[0]}" >&2
        return 2
      }
      exec "$ctl" machine delete-snapshot "$name" "$delete_snapshot_id"
      ;;
    create)
      shift
      name="${1:?usage: dory machine create <name> [--kernel PATH] [--rootfs PATH] [--image-manifest PATH --image-signature PATH --image-allowed-signers PATH --image-signer ID] [--memory-mb N] [--cpus N] [--share TAG=HOST:GUEST[:ro|rw] or JSON] [--env KEY=VALUE]}"
      shift
      local image_manifest="" image_signature="" image_allowed_signers="" image_signer="" forwarded=()
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --image-manifest) image_manifest="${2:?--image-manifest requires a path}"; shift 2 ;;
          --image-signature) image_signature="${2:?--image-signature requires a path}"; shift 2 ;;
          --image-allowed-signers) image_allowed_signers="${2:?--image-allowed-signers requires a path}"; shift 2 ;;
          --image-signer) image_signer="${2:?--image-signer requires an identity}"; shift 2 ;;
          --image-manifest=*|--image-signature=*|--image-allowed-signers=*|--image-signer=*)
            echo "machine image trust options require a separate value, not --option=value" >&2
            exit 2
            ;;
          *) forwarded+=("$1"); shift ;;
        esac
      done
      set -- "${forwarded[@]}"
      args=("$name")
      if ! dory_machine_has_option --kernel "$@"; then
        local kernel
        kernel="$(sandbox_default_kernel || true)"
        [ -n "$kernel" ] || { echo "Linux Machines is not installed. Run: dory component install linux-machines" >&2; exit 1; }
        args+=(--kernel "$kernel")
      fi
      if ! dory_machine_has_option --rootfs "$@"; then
        local rootfs
        rootfs="$(sandbox_default_rootfs || true)"
        [ -n "$rootfs" ] || { echo "Linux Machines is not installed. Run: dory component install linux-machines" >&2; exit 1; }
        args+=(--rootfs "$rootfs")
      fi
      while IFS= read -r env_row; do
        [ -n "$env_row" ] && args+=(--env "$env_row")
      done < <(dory_machine_env_rows)
      if [ -n "$image_manifest$image_signature$image_allowed_signers$image_signer" ]; then
        [ -n "$image_manifest" ] && [ -n "$image_signature" ] && [ -n "$image_allowed_signers" ] && [ -n "$image_signer" ] || {
          echo "signed machine images require --image-manifest, --image-signature, --image-allowed-signers, and --image-signer together" >&2
          exit 2
        }
        local selected_kernel selected_rootfs
        selected_kernel="$(dory_machine_option_value --kernel "${args[@]}" "$@")" || exit 2
        selected_rootfs="$(dory_machine_option_value --rootfs "${args[@]}" "$@")" || exit 2
        verify_dory_machine_image_manifest "$image_manifest" "$image_signature" \
          "$image_allowed_signers" "$image_signer" "$selected_kernel" "$selected_rootfs" || exit 1
      fi
      exec "$ctl" machine create "${args[@]}" "$@"
      ;;
    delete|rm)
      shift
      name="${1:?usage: dory machine delete NAME --confirm NAME}"
      shift
      require_exact_confirmation "machine deletion" "$name" "$@" || return $?
      [ "${#DORY_CONFIRM_REMAINDER[@]}" -eq 0 ] || {
        echo "unexpected machine deletion argument: ${DORY_CONFIRM_REMAINDER[0]}" >&2
        return 2
      }
      exec "$ctl" machine delete "$name"
      ;;
    create|update|start|stop|status|provision|snapshots|snapshot)
      exec "$ctl" machine "$@"
      ;;
    *)
      exec "$ctl" machine "$@"
      ;;
  esac
}

legacy_machine_cmd() {
  case "${1:-ls}" in
    create)
      shift
      if printf '%s\n' "$*" | grep -q -- '--recipe'; then
        machine_create_recipe "$@"
      else
        exec "$CONTAINER_BIN" machine create "$@"
      fi ;;
    snapshot) shift; machine_snapshot_create "$@" ;;
    snapshots|list-snapshots) shift; machine_snapshot_list "$@" ;;
    restore)
      shift
      local restore_name="${1:?usage: dory machine restore NAME SNAPSHOT --confirm NAME}"
      local restore_selector="${2:?usage: dory machine restore NAME SNAPSHOT --confirm NAME}"
      shift 2
      require_exact_confirmation "machine restore" "$restore_name" "$@" || return $?
      [ "${#DORY_CONFIRM_REMAINDER[@]}" -eq 0 ] || { echo "unexpected machine restore argument" >&2; return 2; }
      machine_snapshot_restore "$restore_name" "$restore_selector"
      ;;
    clone) shift; machine_snapshot_clone "$@" ;;
    export) shift; machine_snapshot_export "$@" ;;
    backup) shift; machine_snapshot_backup "$@" ;;
    import) shift; machine_snapshot_import "$@" ;;
    delete-snapshot|rm-snapshot)
      shift
      local legacy_machine="${1:?usage: dory machine delete-snapshot NAME SNAPSHOT --confirm SNAPSHOT}"
      local legacy_snapshot="${2:?usage: dory machine delete-snapshot NAME SNAPSHOT --confirm SNAPSHOT}"
      shift 2
      require_exact_confirmation "snapshot deletion" "$legacy_snapshot" "$@" || return $?
      [ "${#DORY_CONFIRM_REMAINDER[@]}" -eq 0 ] || { echo "unexpected snapshot deletion argument" >&2; return 2; }
      machine_snapshot_delete "$legacy_machine" "$legacy_snapshot"
      ;;
    delete|rm)
      shift
      local legacy_delete_name="${1:?usage: dory machine delete NAME --confirm NAME}"
      shift
      require_exact_confirmation "machine deletion" "$legacy_delete_name" "$@" || return $?
      [ "${#DORY_CONFIRM_REMAINDER[@]}" -eq 0 ] || { echo "unexpected machine deletion argument" >&2; return 2; }
      exec "$CONTAINER_BIN" machine delete "$legacy_delete_name"
      ;;
    *) exec "$CONTAINER_BIN" machine "$@" ;;
  esac
}

machine_cmd() {
  local ctl
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    doryd_machine_cmd "$ctl" "$@"
  fi
  if [ "${DORY_LEGACY_DOCKER_MACHINES:-0}" = "1" ]; then
    # Snapshot-family helpers return normally instead of exec'ing; propagate their status rather
    # than falling through to the "requires dorydctl" error after a successful legacy dispatch.
    local legacy_status=0
    legacy_machine_cmd "$@" || legacy_status=$?
    exit "$legacy_status"
  fi
  echo "dory machine requires dorydctl and Dory's daemon-managed VM machine runtime. Start Dory's engine; set DORY_LEGACY_DOCKER_MACHINES=1 only to inspect old container-backed machines." >&2
  exit 1
}

sandbox_usage() {
  echo "usage: dory sandbox run [--json] [--keep] [--name NAME | --reuse NAME] [--mount HOST[:GUEST[:ro|rw]]] [--network none|outbound|full] [--allow-network HOST[:PORT]] [--secret-env NAME] [--ssh-agent] [--elevated] [--rollback] [--ttl-seconds N] [--wall-time-seconds N] [--processes N] [--open-files N] [--disk-mb N] [--memory-mb N] [--cpus N] [--kernel PATH] [--rootfs PATH] -- <command...>" >&2
  echo "       dory sandbox inspect NAME [--json]" >&2
  echo "       dory sandbox list [--json]" >&2
  echo "       dory sandbox kill NAME" >&2
  echo "  none is the safe default; outbound permits DNS only to Dory's resolver plus explicit --allow-network destinations." >&2
  echo "  mounts default to read-only; use a trailing :rw for an explicit write grant." >&2
  echo "  workloads run as a non-root uid. --elevated is explicit and is accepted only with --network full." >&2
}

first_file() {
  local cand
  for cand in "$@"; do
    [ -n "$cand" ] && [ -f "$cand" ] && { printf '%s\n' "$cand"; return 0; }
  done
  return 1
}

sandbox_default_kernel() {
  local arch repo
  arch="$(host_guest_arch)"
  repo="$(cd "$DORY_SCRIPT_DIR/.." >/dev/null 2>&1 && pwd || true)"
  first_file \
    "${DORY_SANDBOX_KERNEL:-}" \
    "${DORYD_MACHINE_KERNEL:-}" \
    "${DORYD_GUEST_KERNEL:-}" \
    "$(installed_component_asset linux-machines "dory-hv-kernel-$arch" || true)" \
    "$(installed_component_asset linux-machines dory-hv-kernel || true)" \
    "$DORY_SCRIPT_DIR/../Resources/dory-hv-kernel-$arch" \
    "$DORY_SCRIPT_DIR/../Resources/dory-hv-kernel" \
    "$repo/guest/out/Image" \
    "$repo/guest/out/bzImage-x86"
}

sandbox_default_rootfs() {
  local arch repo
  arch="$(host_guest_arch)"
  repo="$(cd "$DORY_SCRIPT_DIR/.." >/dev/null 2>&1 && pwd || true)"
  first_file \
    "${DORY_SANDBOX_ROOTFS:-}" \
    "${DORYD_MACHINE_ROOTFS:-}" \
    "${DORYD_GUEST_ROOTFS:-}" \
    "$(installed_component_asset linux-machines "dory-machine-rootfs-$arch.ext4" || true)" \
    "$(installed_component_asset linux-machines dory-machine-rootfs.ext4 || true)" \
    "$DORY_SCRIPT_DIR/../Resources/dory-machine-rootfs-$arch.ext4" \
    "$DORY_SCRIPT_DIR/../Resources/dory-machine-rootfs.ext4" \
    "$repo/guest/out/initfs-$arch.ext4"
}

sandbox_error_json() {
  python3 - "$1" "$2" <<'PY'
import json
import sys
print(json.dumps({
    "schema": "dev.dory.sandbox.error",
    "version": 1,
    "code": sys.argv[1],
    "message": sys.argv[2],
}, separators=(",", ":"), sort_keys=True))
PY
}

sandbox_parse_mount() {
  python3 - "$1" "$2" <<'PY'
import os
import sys

raw, index = sys.argv[1], int(sys.argv[2])
mode = "ro"
parts = raw.split(":")
if parts and parts[-1] in ("ro", "rw"):
    mode = parts.pop()
if len(parts) == 1:
    host = parts[0]
    guest = ""
elif len(parts) >= 2:
    guest = parts.pop()
    host = ":".join(parts)
else:
    print("empty mount", file=sys.stderr)
    sys.exit(2)

host = os.path.abspath(os.path.expanduser(host))
if not os.path.isdir(host):
    print(f"sandbox mount host path must be an existing directory: {host}", file=sys.stderr)
    sys.exit(2)
if not guest:
    base = os.path.basename(os.path.realpath(host).rstrip(os.sep)) or "project"
    guest = f"/workspace/{base}"
if not guest.startswith("/") or guest == "/":
    print(f"sandbox mount guest path must be absolute and not /: {guest}", file=sys.stderr)
    sys.exit(2)
if guest == "/dory-sandbox" or guest.startswith("/dory-sandbox/") or guest.startswith("/run/host-services"):
    print(f"sandbox mount guest path is reserved by Dory: {guest}", file=sys.stderr)
    sys.exit(2)
tag = f"dorysb{index}"
print("\t".join([tag, host, guest, mode]))
PY
}

sandbox_state_directory() {
  printf '%s\n' "${DORY_SANDBOX_STATE_DIR:-$HOME/.dory/sandboxes}"
}

sandbox_manifest_path() {
  printf '%s/%s.json\n' "$(sandbox_state_directory)" "$1"
}

sandbox_resolve_egress() {
  local output="$1"
  shift
  python3 - "$output" "$@" <<'PY'
import ipaddress
import json
import os
import socket
import sys

output, specs = sys.argv[1], sys.argv[2:]
grants = []
for spec in specs:
    if "/" in spec or "://" in spec:
        raise SystemExit(f"invalid --allow-network destination: {spec}")
    host = spec
    port = 443
    if spec.startswith("["):
        end = spec.find("]")
        if end < 0:
            raise SystemExit(f"invalid bracketed IPv6 destination: {spec}")
        host = spec[1:end]
        suffix = spec[end + 1:]
        if suffix:
            if not suffix.startswith(":"):
                raise SystemExit(f"invalid --allow-network destination: {spec}")
            port = int(suffix[1:])
    elif spec.count(":") == 1 and spec.rsplit(":", 1)[1].isdigit():
        host, raw_port = spec.rsplit(":", 1)
        port = int(raw_port)
    if not host or not 1 <= port <= 65535:
        raise SystemExit(f"invalid --allow-network destination: {spec}")
    try:
        ipaddress.ip_address(host)
        addresses = [host]
    except ValueError:
        try:
            addresses = sorted({
                row[4][0]
                for row in socket.getaddrinfo(host, port, socket.AF_UNSPEC, socket.SOCK_STREAM)
            })
        except OSError as error:
            raise SystemExit(f"could not resolve --allow-network destination {host}: {error}")
    if not addresses:
        raise SystemExit(f"--allow-network destination resolved to no addresses: {host}")
    grants.append({"host": host, "port": port, "addresses": addresses})

directory = os.path.dirname(output)
os.makedirs(directory, mode=0o700, exist_ok=True)
with open(output, "w", encoding="utf-8") as handle:
    json.dump(grants, handle, separators=(",", ":"), sort_keys=True)
PY
}

sandbox_policy_rows() {
  python3 - "$1" <<'PY'
import ipaddress
import json
import sys

for grant in json.load(open(sys.argv[1], encoding="utf-8")):
    for raw in grant["addresses"]:
        address = ipaddress.ip_address(raw)
        print("\t".join(("6" if address.version == 6 else "4", str(address), str(grant["port"]))))
PY
}

sandbox_apply_guest_policy() {
  local ctl="$1" name="$2" network="$3" uid="$4" gid="$5" disk_mb="$6" egress_json="$7"
  local policy_args=() family address port
  while IFS=$'\t' read -r family address port; do
    [ -n "$family" ] && policy_args+=("$family" "$address" "$port")
  done < <(sandbox_policy_rows "$egress_json")

  "$ctl" --timeout 120 machine exec "$name" --json -- /bin/sh -eu -c '
uid="$1"; gid="$2"; network="$3"; disk_mb="$4"; shift 4
command -v iptables >/dev/null
command -v mkfs.ext4 >/dev/null
command -v losetup >/dev/null

mkdir -p /var/lib/dory-sandbox /dory-sandbox
disk=/var/lib/dory-sandbox/workspace.ext4
if [ ! -f "$disk" ]; then
  free_mb="$(df -Pm /var/lib/dory-sandbox | awk 'NR == 2 { print $4 }')"
  [ -n "$free_mb" ] && [ "$free_mb" -ge "$((disk_mb + 64))" ] || {
    echo "sandbox scratch disk needs ${disk_mb} MiB plus 64 MiB guest reserve; ${free_mb:-0} MiB is available" >&2
    exit 1
  }
  truncate -s "${disk_mb}M" "$disk"
  mkfs.ext4 -q -F -L dory-sandbox "$disk"
fi
if ! mountpoint /dory-sandbox; then
  mount -t ext4 -o loop,noatime,nodev,nosuid "$disk" /dory-sandbox
fi
mkdir -p /dory-sandbox/.home /dory-sandbox/.tmp
chown -R "$uid:$gid" /dory-sandbox
chmod 0700 /dory-sandbox /dory-sandbox/.home /dory-sandbox/.tmp
chmod 0755 /tmp 2>/dev/null || true
chmod 0755 /var/tmp 2>/dev/null || true

chain=DORY_SANDBOX
while iptables -w 5 -D OUTPUT -m owner --uid-owner "$uid" -j "$chain" 2>/dev/null; do :; done

ipv6=0
if [ -s /proc/net/if_inet6 ] && command -v ip6tables >/dev/null; then
  ipv6=1
  while ip6tables -w 5 -D OUTPUT -m owner --uid-owner "$uid" -j "$chain" 2>/dev/null; do :; done
fi
if [ "$network" = full ]; then
  exit 0
fi
iptables -w 5 -N "$chain" 2>/dev/null || true
iptables -w 5 -F "$chain"
iptables -w 5 -A OUTPUT -m owner --uid-owner "$uid" -j "$chain"
if [ "$ipv6" -eq 1 ]; then
  ip6tables -w 5 -N "$chain" 2>/dev/null || true
  ip6tables -w 5 -F "$chain"
  ip6tables -w 5 -A OUTPUT -m owner --uid-owner "$uid" -j "$chain"
fi

if [ "$network" = outbound ]; then
  iptables -w 5 -A "$chain" -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
  iptables -w 5 -A "$chain" -d 192.168.127.1 -p udp --dport 53 -j ACCEPT
  iptables -w 5 -A "$chain" -d 192.168.127.1 -p tcp --dport 53 -j ACCEPT
  [ "$ipv6" -eq 0 ] || ip6tables -w 5 -A "$chain" -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
  while [ "$#" -gt 0 ]; do
    family="$1"; address="$2"; port="$3"; shift 3
    if [ "$family" = 4 ]; then
      iptables -w 5 -A "$chain" -d "$address" -p tcp --dport "$port" -j ACCEPT
      iptables -w 5 -A "$chain" -d "$address" -p udp --dport "$port" -j ACCEPT
    elif [ "$ipv6" -eq 1 ]; then
      ip6tables -w 5 -A "$chain" -d "$address" -p tcp --dport "$port" -j ACCEPT
      ip6tables -w 5 -A "$chain" -d "$address" -p udp --dport "$port" -j ACCEPT
    fi
  done
fi

# Default DROP also covers loopback, link-local metadata, the host gateway, RFC1918/ULA LANs, and
# every ungranted DNS endpoint. The only gateway exception is Dory DNS above.
iptables -w 5 -A "$chain" -j DROP
[ "$ipv6" -eq 0 ] || ip6tables -w 5 -A "$chain" -j DROP
  ' sh "$uid" "$gid" "$network" "$disk_mb" ${policy_args[@]+"${policy_args[@]}"}
}

sandbox_exec_environment_json() {
  local uid="$1" gid="$2" processes="$3" disk_bytes="$4" open_files="$5" ssh_agent="$6"
  shift 6
  python3 - "$uid" "$gid" "$processes" "$disk_bytes" "$open_files" "$ssh_agent" "$@" <<'PY'
import json
import os
import re
import sys

uid, gid, processes, disk_bytes, open_files, ssh_agent, *names = sys.argv[1:]
environment = {
    "DORY_AGENT_RUN_UID": uid,
    "DORY_AGENT_RUN_GID": gid,
    "DORY_AGENT_MAX_PROCESSES": processes,
    "DORY_AGENT_MAX_FILE_BYTES": disk_bytes,
    "DORY_AGENT_MAX_OPEN_FILES": open_files,
    "HOME": "/dory-sandbox/.home",
    "TMPDIR": "/dory-sandbox/.tmp",
    "DORY_SCRATCH": "/dory-sandbox",
}
if ssh_agent == "1":
    environment["SSH_AUTH_SOCK"] = "/run/host-services/ssh-auth.sock"
for name in names:
    if not re.fullmatch(r"[A-Za-z_][A-Za-z0-9_]*", name):
        raise SystemExit(f"invalid --secret-env name: {name}")
    if name not in os.environ:
        raise SystemExit(f"--secret-env is not set in the host environment: {name}")
    environment[name] = os.environ[name]
print(json.dumps(environment, separators=(",", ":"), sort_keys=True))
PY
}

sandbox_write_manifest() {
  local name="$1" status="$2" network="$3" uid="$4" gid="$5" elevated="$6" memory="$7" cpus="$8"
  local disk_mb="$9" processes="${10}" open_files="${11}" wall_seconds="${12}" ttl_expires="${13}" kept="${14}"
  local ssh_agent="${15}" mounts_json="${16}" egress_json="${17}" executable="${18}" argument_count="${19}"
  shift 19
  local state_dir path
  state_dir="$(sandbox_state_directory)"
  path="$(sandbox_manifest_path "$name")"
  mkdir -p "$state_dir"
  chmod 0700 "$state_dir"
  umask 077
  python3 - "$path" "$name" "$status" "$network" "$uid" "$gid" "$elevated" "$memory" "$cpus" "$disk_mb" "$processes" "$open_files" "$wall_seconds" "$ttl_expires" "$kept" "$ssh_agent" "$mounts_json" "$egress_json" "$executable" "$argument_count" "$@" <<'PY'
import json
import os
import pathlib
import sys
import tempfile
import time

(path, name, status, network, uid, gid, elevated, memory, cpus, disk_mb, processes,
 open_files, wall_seconds, ttl_expires, kept, ssh_agent, mounts_path, egress_path, executable,
 argument_count, *secret_names) = sys.argv[1:]
target = pathlib.Path(path)
existing = {}
try:
    existing = json.loads(target.read_text(encoding="utf-8"))
except Exception:
    pass
manifest = {
    "schema": "dev.dory.sandbox.manifest",
    "version": 1,
    "sandbox": name,
    "machine": name,
    "isolation": "dedicated-vm",
    "status": status,
    "createdEpoch": existing.get("createdEpoch", int(time.time())),
    "updatedEpoch": int(time.time()),
    "expiresEpoch": int(ttl_expires),
    "persistence": "named" if kept == "1" else "disposable",
    "identity": {"uid": int(uid), "gid": int(gid), "elevated": elevated == "1"},
    "network": {
        "mode": network,
        "modeEnforced": True,
        "egressFilterEnforced": network != "full",
        "dns": "dory-resolver-only" if network == "outbound" else ("blocked" if network == "none" else "unrestricted"),
        "defaultDenyPrivateLANMetadataHostLoopback": network != "full",
        "grants": json.load(open(egress_path, encoding="utf-8")),
    },
    "mounts": json.load(open(mounts_path, encoding="utf-8")),
    "credentials": {"secretEnvironmentNames": sorted(secret_names), "sshAgent": ssh_agent == "1"},
    "limits": {
        "cpus": int(cpus), "memoryMB": int(memory), "diskMB": int(disk_mb),
        "processes": int(processes), "openFiles": int(open_files),
        "wallTimeSeconds": int(wall_seconds),
    },
    "command": {"executable": executable, "argumentCount": int(argument_count), "argumentsPersisted": False},
}
fd, temporary = tempfile.mkstemp(prefix=".sandbox-manifest-", dir=str(target.parent))
try:
    with os.fdopen(fd, "w", encoding="utf-8") as handle:
        json.dump(manifest, handle, separators=(",", ":"), sort_keys=True)
        handle.write("\n")
        handle.flush()
        os.fsync(handle.fileno())
    os.chmod(temporary, 0o600)
    os.replace(temporary, target)
finally:
    if os.path.exists(temporary):
        os.unlink(temporary)
PY
}

sandbox_inspect_cmd() {
  local name="${1:?usage: dory sandbox inspect NAME [--json]}" json=0 path
  shift
  [ "${1:-}" != "--json" ] || { json=1; shift; }
  [ "$#" -eq 0 ] || { sandbox_usage; return 2; }
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*$ ]] || { echo "invalid sandbox name: $name" >&2; return 2; }
  path="$(sandbox_manifest_path "$name")"
  [ -f "$path" ] || { echo "sandbox manifest not found: $name" >&2; return 1; }
  if [ "$json" -eq 1 ]; then cat "$path"; else python3 -m json.tool "$path"; fi
}

sandbox_list_cmd() {
  local json=0 state_dir
  [ "${1:-}" != "--json" ] || { json=1; shift; }
  [ "$#" -eq 0 ] || { sandbox_usage; return 2; }
  state_dir="$(sandbox_state_directory)"
  python3 - "$state_dir" "$json" <<'PY'
import json
import pathlib
import sys

root, as_json = pathlib.Path(sys.argv[1]), sys.argv[2] == "1"
rows = []
if root.is_dir():
    for path in sorted(root.glob("*.json")):
        try:
            rows.append(json.loads(path.read_text(encoding="utf-8")))
        except Exception:
            continue
if as_json:
    print(json.dumps({"schema":"dev.dory.sandbox.list","version":1,"sandboxes":rows}, separators=(",",":"), sort_keys=True))
else:
    for row in rows:
        print(f"{row.get('sandbox','?')}\t{row.get('status','?')}\t{row.get('persistence','?')}\t{row.get('network',{}).get('mode','?')}")
PY
}

sandbox_kill_cmd() {
  local name="${1:?usage: dory sandbox kill NAME}" ctl path
  shift
  [ "$#" -eq 0 ] || { sandbox_usage; return 2; }
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*$ ]] || { echo "invalid sandbox name: $name" >&2; return 2; }
  ctl="$(dorydctl_bin 2>/dev/null)" || { echo "dorydctl not found" >&2; return 1; }
  "$ctl" --timeout 60 machine stop "$name" >/dev/null 2>&1 || true
  "$ctl" --timeout 60 machine delete "$name" >/dev/null
  path="$(sandbox_manifest_path "$name")"
  if [ -f "$path" ]; then
    python3 - "$path" <<'PY'
import json, os, sys, tempfile, time
path = sys.argv[1]
data = json.load(open(path, encoding="utf-8"))
data["status"] = "killed"
data["updatedEpoch"] = int(time.time())
fd, temporary = tempfile.mkstemp(prefix=".sandbox-manifest-", dir=os.path.dirname(path))
with os.fdopen(fd, "w", encoding="utf-8") as handle:
    json.dump(data, handle, separators=(",",":"), sort_keys=True); handle.write("\n")
os.chmod(temporary, 0o600); os.replace(temporary, path)
PY
  fi
  echo "sandbox killed: $name"
}

sandbox_emit_run_result() {
  local name="$1" kept="$2" exit_code="$3" json="$4" tmp="$5" network="$6" rollback="$7" ttl_seconds="$8" snapshot_id="$9" manifest_path="${10}"
  python3 - "$name" "$kept" "$exit_code" "$json" "$tmp" "$network" "$rollback" "$ttl_seconds" "$snapshot_id" "$manifest_path" <<'PY'
import json
import pathlib
import sys

name, kept, exit_code, as_json, tmp, network, rollback, ttl_seconds, snapshot_id, manifest_path = sys.argv[1:11]
root = pathlib.Path(tmp)

def read_json(name: str, default):
    path = root / name
    try:
        return json.loads(path.read_text(encoding="utf-8") or "null")
    except Exception:
        return default

exec_result = read_json("exec.json", {})
mounts = read_json("mounts.json", [])
cleanup = {
    "stopped": (root / "stop.json").exists(),
    "deleted": (root / "delete.json").exists(),
}
rollback_result = {
    "requested": rollback == "1",
    "snapshotID": snapshot_id or None,
    "created": (root / "snapshot.json").exists(),
    "restored": (root / "rollback.json").exists(),
    "snapshotDeleted": (root / "delete-snapshot.json").exists(),
}
ttl = {
    "seconds": int(ttl_seconds),
    "scheduled": int(ttl_seconds) > 0 and kept == "1",
}
manifest = None
try:
    manifest = json.loads(pathlib.Path(manifest_path).read_text(encoding="utf-8"))
except Exception:
    manifest = None
result = {
    "schema": "dev.dory.sandbox.run",
    "version": 2,
    "sandbox": name,
    "machine": name,
    "isolation": "dedicated-vm",
    "networkPolicy": network,
    "networkPolicyEnforced": True,
    "hostFileSharing": "scoped" if mounts else "none",
    "mounts": mounts,
    "rollback": rollback_result,
    "ttl": ttl,
    "kept": kept == "1",
    "exitCode": int(exit_code),
    "exec": exec_result,
    "cleanup": cleanup,
    "manifest": manifest,
}
if as_json == "1":
    print(json.dumps(result, separators=(",", ":"), sort_keys=True))
else:
    stdout = exec_result.get("stdout", "")
    stderr = exec_result.get("stderr", "")
    if stdout:
        print(stdout, end="")
    if stderr:
        print(stderr, end="", file=sys.stderr)
PY
}

sandbox_run_cmd() {
  local ctl name="" keep=0 reuse=0 json=0 memory=2048 cpus=2 disk_mb=256 processes=128 open_files=1024
  local wall_seconds=600 kernel="" rootfs="" tmp exec_rc=0 created=0 cwd="/dory-sandbox"
  local network="none" rollback=0 ttl_seconds=0 expires_epoch=0 snapshot_id="" rollback_failed=0
  local ssh_agent=0 elevated=0 uid gid now_epoch manifest_path producer_rc=0 command_argc
  local mounts=() mount_tags=() mount_guests=() mount_modes=() mount_rows=() create_args=()
  local allow_network=() secret_env=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      --keep) keep=1; shift ;;
      --name) name="${2:?--name requires a value}"; shift 2 ;;
      --reuse) name="${2:?--reuse requires a name}"; reuse=1; keep=1; shift 2 ;;
      --memory-mb) memory="${2:?--memory-mb requires a value}"; shift 2 ;;
      --cpus) cpus="${2:?--cpus requires a value}"; shift 2 ;;
      --disk-mb) disk_mb="${2:?--disk-mb requires a value}"; shift 2 ;;
      --processes) processes="${2:?--processes requires a value}"; shift 2 ;;
      --open-files) open_files="${2:?--open-files requires a value}"; shift 2 ;;
      --wall-time-seconds) wall_seconds="${2:?--wall-time-seconds requires a value}"; shift 2 ;;
      --kernel) kernel="${2:?--kernel requires a value}"; shift 2 ;;
      --rootfs) rootfs="${2:?--rootfs requires a value}"; shift 2 ;;
      --mount) mounts+=("${2:?--mount requires a path}"); shift 2 ;;
      --network) network="${2:?--network requires none, outbound, or full}"; shift 2 ;;
      --allow-network) allow_network+=("${2:?--allow-network requires HOST[:PORT]}"); shift 2 ;;
      --secret-env) secret_env+=("${2:?--secret-env requires a host environment variable name}"); shift 2 ;;
      --ssh-agent) ssh_agent=1; shift ;;
      --elevated) elevated=1; shift ;;
      --rollback) rollback=1; shift ;;
      --ttl-seconds) ttl_seconds="${2:?--ttl-seconds requires a value}"; shift 2 ;;
      --) shift; break ;;
      -h|--help) sandbox_usage; return 0 ;;
      --*) echo "unknown sandbox option: $1" >&2; sandbox_usage; exit 2 ;;
      *) break ;;
    esac
  done
  [ "$#" -gt 0 ] || { sandbox_usage; exit 2; }
  command_argc="$#"
  [[ "$memory" =~ ^[0-9]+$ ]] && [ "$memory" -ge 1024 ] && [ "$memory" -le 16384 ] || { echo "invalid --memory-mb: $memory (expected 1024..16384)" >&2; exit 2; }
  [[ "$cpus" =~ ^[0-9]+$ ]] && [ "$cpus" -ge 1 ] && [ "$cpus" -le 8 ] || { echo "invalid --cpus: $cpus (expected 1..8)" >&2; exit 2; }
  [[ "$disk_mb" =~ ^[0-9]+$ ]] && [ "$disk_mb" -ge 32 ] && [ "$disk_mb" -le 640 ] || { echo "invalid --disk-mb: $disk_mb (expected 32..640)" >&2; exit 2; }
  [[ "$processes" =~ ^[0-9]+$ ]] && [ "$processes" -ge 1 ] && [ "$processes" -le 4096 ] || { echo "invalid --processes: $processes (expected 1..4096)" >&2; exit 2; }
  [[ "$open_files" =~ ^[0-9]+$ ]] && [ "$open_files" -ge 16 ] && [ "$open_files" -le 65536 ] || { echo "invalid --open-files: $open_files (expected 16..65536)" >&2; exit 2; }
  [[ "$wall_seconds" =~ ^[0-9]+$ ]] && [ "$wall_seconds" -ge 1 ] && [ "$wall_seconds" -le 600 ] || { echo "invalid --wall-time-seconds: $wall_seconds (expected 1..600)" >&2; exit 2; }
  case "$network" in
    none|outbound|full) ;;
    *) echo "invalid --network: $network (expected none, outbound, or full)" >&2; exit 2 ;;
  esac
  [[ "$ttl_seconds" =~ ^[0-9]+$ ]] || { echo "invalid --ttl-seconds: $ttl_seconds" >&2; exit 2; }
  if [ "$network" = outbound ] && [ "${#allow_network[@]}" -eq 0 ]; then
    echo "--network outbound requires at least one --allow-network HOST[:PORT] grant" >&2
    exit 2
  fi
  if [ "$network" != outbound ] && [ "${#allow_network[@]}" -gt 0 ]; then
    echo "--allow-network is valid only with --network outbound" >&2
    exit 2
  fi
  if [ "$elevated" -eq 1 ] && [ "$network" != full ]; then
    echo "--elevated requires --network full because root can alter guest firewall policy" >&2
    exit 2
  fi
  if [ "$ttl_seconds" -gt 0 ] && [ "$keep" -ne 1 ]; then
    echo "--ttl-seconds requires --keep (or --reuse)" >&2
    exit 2
  fi
  if [ "$reuse" -eq 1 ] && [ "$ttl_seconds" -gt 0 ]; then
    echo "a reused sandbox retains its original crash-safe expiry; create a new named sandbox to choose another TTL" >&2
    exit 2
  fi
  if [ "$reuse" -eq 1 ] && [ "${#mounts[@]}" -gt 0 ]; then
    echo "a reused sandbox retains its original mount grants; omit --mount and inspect the persisted manifest first" >&2
    exit 2
  fi

  if [ "$elevated" -eq 1 ]; then
    uid=0; gid=0
  else
    uid="$(id -u)"; gid="$(id -g)"
    if [ "$uid" -eq 0 ]; then uid=65534; gid=65534; fi
  fi

  local parsed tag host guest mode mount_index=0
  if [ "${#mounts[@]}" -gt 0 ]; then
    for raw_mount in "${mounts[@]}"; do
      if ! parsed="$(sandbox_parse_mount "$raw_mount" "$mount_index")"; then
        if [ "$json" -eq 1 ]; then sandbox_error_json "sandbox.invalid_mount" "invalid sandbox mount: $raw_mount"; fi
        exit 2
      fi
      IFS=$'\t' read -r tag host guest mode <<<"$parsed"
      mount_tags+=("$tag")
      mount_guests+=("$guest")
      mount_modes+=("$mode")
      mount_rows+=("$tag" "$host" "$guest" "$mode")
      create_args+=(--share "$tag=$host:$guest:$mode")
      [ "$cwd" != "/dory-sandbox" ] || cwd="$guest"
      mount_index=$((mount_index + 1))
    done
  fi

  ctl="$(dorydctl_bin 2>/dev/null)" || { echo "dorydctl not found; build/install doryd before using sandboxes" >&2; exit 1; }
  [ -n "$name" ] || name="dory-sandbox-$(date +%Y%m%d%H%M%S)-$RANDOM"
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9_.-]*$ ]] || { echo "invalid sandbox name: $name" >&2; exit 2; }

  tmp="$(mktemp -d -t dory-sandbox.XXXXXX)"
  python3 - "$tmp/mounts.json" ${mount_rows[@]+"${mount_rows[@]}"} <<'PY'
import json
import sys

path = sys.argv[1]
rows = sys.argv[2:]
mounts = []
for index in range(0, len(rows), 4):
    tag, host, guest, mode = rows[index:index + 4]
    mounts.append({
        "tag": tag,
        "hostPath": host,
        "guestPath": guest,
        "mode": mode,
        "readOnly": mode == "ro",
    })
with open(path, "w", encoding="utf-8") as handle:
    json.dump(mounts, handle, separators=(",", ":"), sort_keys=True)
PY
  sandbox_resolve_egress "$tmp/egress.json" ${allow_network[@]+"${allow_network[@]}"} || { rm -rf "$tmp"; exit 2; }
  now_epoch="$(date +%s)"
  if [ "$reuse" -eq 0 ]; then
    kernel="${kernel:-$(sandbox_default_kernel || true)}"
    rootfs="${rootfs:-$(sandbox_default_rootfs || true)}"
    [ -n "$kernel" ] && [ -f "$kernel" ] || { echo "sandbox kernel not found; set DORY_SANDBOX_KERNEL or build guest assets" >&2; rm -rf "$tmp"; exit 1; }
    [ -n "$rootfs" ] && [ -f "$rootfs" ] || { echo "sandbox rootfs not found; set DORY_SANDBOX_ROOTFS or build guest assets" >&2; rm -rf "$tmp"; exit 1; }
    if [ "$keep" -eq 1 ] && [ "$ttl_seconds" -gt 0 ]; then
      expires_epoch=$((now_epoch + ttl_seconds))
    elif [ "$keep" -eq 0 ]; then
      expires_epoch=$((now_epoch + wall_seconds + 300))
    fi
    create_args+=(--env "DORY_SANDBOX=1" --env "DORY_SANDBOX_EXPIRES_AT=$expires_epoch" --env "DORY_SANDBOX_SSH_AGENT=$ssh_agent")
    if ! "$ctl" --timeout 120 machine create "$name" --kernel "$kernel" --rootfs "$rootfs" --memory-mb "$memory" --cpus "$cpus" "${create_args[@]}" > "$tmp/create.json"; then
      rm -rf "$tmp"; exit 1
    fi
    created=1
    if ! "$ctl" --timeout 120 machine start "$name" > "$tmp/start.json"; then
      [ "$keep" -eq 1 ] || "$ctl" --timeout 30 machine delete "$name" > "$tmp/delete.json" 2>/dev/null || true
      rm -rf "$tmp"; exit 1
    fi
  else
    if ! "$ctl" --timeout 30 machine status "$name" > "$tmp/status.json"; then rm -rf "$tmp"; exit 1; fi
    manifest_path="$(sandbox_manifest_path "$name")"
    [ -f "$manifest_path" ] || { echo "sandbox manifest not found; refusing uninspectable reuse: $name" >&2; rm -rf "$tmp"; exit 2; }
    local reuse_meta
    if ! reuse_meta="$(python3 - "$tmp/status.json" "$manifest_path" "$ssh_agent" "$now_epoch" <<'PY'
import json, sys
status = json.load(open(sys.argv[1], encoding="utf-8"))
manifest = json.load(open(sys.argv[2], encoding="utf-8"))
requested_ssh = sys.argv[3] == "1"
now = int(sys.argv[4])
environment = {row["key"]: row["value"] for row in status.get("env", [])}
if environment.get("DORY_SANDBOX") != "1":
    raise SystemExit("refusing to reuse a machine that was not created as a sandbox")
expires = int(environment.get("DORY_SANDBOX_EXPIRES_AT", "0"))
if expires and expires <= now:
    raise SystemExit("sandbox TTL has expired; wait for daemon cleanup or kill it explicitly")
granted_ssh = environment.get("DORY_SANDBOX_SSH_AGENT") == "1"
if granted_ssh != requested_ssh:
    raise SystemExit("--ssh-agent must exactly match the retained sandbox credential grant")
expected_mounts = manifest.get("mounts", [])
actual_mounts = status.get("shares", [])
expected = sorted((m["tag"], m["hostPath"], m["guestPath"], bool(m["readOnly"])) for m in expected_mounts)
actual = sorted((m["tag"], m["hostPath"], m["guestPath"], bool(m["readOnly"])) for m in actual_mounts)
if expected != actual:
    raise SystemExit("retained sandbox mounts differ from its manifest; refusing reuse")
limits = manifest.get("limits", {})
print("\t".join((
    str(status.get("memoryMB", limits.get("memoryMB", 2048))),
    str(status.get("cpuCount", limits.get("cpus", 2))),
    str(limits.get("diskMB", 256)), str(expires), status.get("state", "stopped"),
)))
PY
)"; then rm -rf "$tmp"; exit 2; fi
    local reuse_state
    IFS=$'\t' read -r memory cpus disk_mb expires_epoch reuse_state <<<"$reuse_meta"
    python3 - "$manifest_path" "$tmp/mounts.json" <<'PY'
import json, sys
manifest = json.load(open(sys.argv[1], encoding="utf-8"))
with open(sys.argv[2], "w", encoding="utf-8") as handle:
    json.dump(manifest.get("mounts", []), handle, separators=(",",":"), sort_keys=True)
PY
    mount_guests=()
    mount_modes=()
    while IFS=$'\t' read -r guest mode; do
      [ -n "$guest" ] || continue
      mount_guests+=("$guest"); mount_modes+=("$mode")
      [ "$cwd" != "/dory-sandbox" ] || cwd="$guest"
    done < <(python3 - "$tmp/mounts.json" <<'PY'
import json, sys
for mount in json.load(open(sys.argv[1], encoding="utf-8")):
    print(f"{mount['guestPath']}\t{mount['mode']}")
PY
)
    if [ "$reuse_state" != running ]; then
      "$ctl" --timeout 120 machine start "$name" > "$tmp/start.json" || { rm -rf "$tmp"; exit 1; }
    fi
  fi

  if ! sandbox_apply_guest_policy "$ctl" "$name" "$network" "$uid" "$gid" "$disk_mb" "$tmp/egress.json" > "$tmp/network.json"; then
    [ "$keep" -eq 1 ] || "$ctl" --timeout 60 machine delete "$name" > "$tmp/delete.json" 2>/dev/null || true
    rm -rf "$tmp"; exit 1
  fi

  local idx=0
  while [ "$idx" -lt "${#mount_guests[@]}" ]; do
    if ! "$ctl" --timeout 30 machine exec "$name" --json -- /bin/sh -eu -c 'mountpoint "$1" >/dev/null' sh "${mount_guests[$idx]}" > "$tmp/mount-$idx.json"; then
      echo "sandbox share was not mounted in the guest: ${mount_guests[$idx]}" >&2
      [ "$keep" -eq 1 ] || "$ctl" --timeout 60 machine delete "$name" > "$tmp/delete.json" 2>/dev/null || true
      rm -rf "$tmp"; exit 1
    fi
    idx=$((idx + 1))
  done

  if [ "$rollback" -eq 1 ]; then
    snapshot_id="dory-sandbox-pre-$(date +%s)-$RANDOM"
    if ! "$ctl" --timeout 120 machine snapshot "$name" --id "$snapshot_id" --note "pre-sandbox-run" > "$tmp/snapshot.json"; then
      [ "$keep" -eq 1 ] || "$ctl" --timeout 60 machine delete "$name" > "$tmp/delete.json" 2>/dev/null || true
      rm -rf "$tmp"
      exit 1
    fi
  fi

  manifest_path="$(sandbox_manifest_path "$name")"
  sandbox_write_manifest "$name" running "$network" "$uid" "$gid" "$elevated" "$memory" "$cpus" "$disk_mb" "$processes" "$open_files" "$wall_seconds" "$expires_epoch" "$keep" "$ssh_agent" "$tmp/mounts.json" "$tmp/egress.json" "$1" "$command_argc" ${secret_env[@]+"${secret_env[@]}"}

  set +e
  local pipeline_status=()
  if [ -n "$cwd" ]; then
    sandbox_exec_environment_json "$uid" "$gid" "$processes" "$((disk_mb * 1024 * 1024))" "$open_files" "$ssh_agent" ${secret_env[@]+"${secret_env[@]}"} \
      | "$ctl" --timeout "$((wall_seconds + 15))" machine exec "$name" --json --cwd "$cwd" --env-json-stdin --timeout-ms "$((wall_seconds * 1000))" -- "$@" > "$tmp/exec.json"
  else
    sandbox_exec_environment_json "$uid" "$gid" "$processes" "$((disk_mb * 1024 * 1024))" "$open_files" "$ssh_agent" ${secret_env[@]+"${secret_env[@]}"} \
      | "$ctl" --timeout "$((wall_seconds + 15))" machine exec "$name" --json --env-json-stdin --timeout-ms "$((wall_seconds * 1000))" -- "$@" > "$tmp/exec.json"
  fi
  pipeline_status=("${PIPESTATUS[@]}")
  producer_rc="${pipeline_status[0]:-1}"
  exec_rc="${pipeline_status[1]:-1}"
  set -e
  if [ "$producer_rc" -ne 0 ]; then exec_rc="$producer_rc"; fi

  if [ "$rollback" -eq 1 ]; then
    if ! "$ctl" --timeout 180 machine restore-snapshot "$name" "$snapshot_id" > "$tmp/rollback.json"; then
      rollback_failed=1
    fi
    "$ctl" --timeout 60 machine delete-snapshot "$name" "$snapshot_id" > "$tmp/delete-snapshot.json" 2>/dev/null || true
    if [ "$rollback_failed" -eq 1 ] && [ "$exec_rc" -eq 0 ]; then
      exec_rc=1
    fi
  fi

  if [ "$keep" -eq 0 ] && [ "$created" -eq 1 ]; then
    "$ctl" --timeout 60 machine stop "$name" > "$tmp/stop.json" 2>/dev/null || true
    "$ctl" --timeout 60 machine delete "$name" > "$tmp/delete.json" 2>/dev/null || true
  fi
  local final_status=retained
  [ "$keep" -eq 1 ] || final_status=deleted
  sandbox_write_manifest "$name" "$final_status" "$network" "$uid" "$gid" "$elevated" "$memory" "$cpus" "$disk_mb" "$processes" "$open_files" "$wall_seconds" "$expires_epoch" "$keep" "$ssh_agent" "$tmp/mounts.json" "$tmp/egress.json" "$1" "$command_argc" ${secret_env[@]+"${secret_env[@]}"}
  sandbox_emit_run_result "$name" "$keep" "$exec_rc" "$json" "$tmp" "$network" "$rollback" "$ttl_seconds" "$snapshot_id" "$manifest_path"
  rm -rf "$tmp"
  exit "$exec_rc"
}

sandbox_cmd() {
  case "${1:-run}" in
    run) shift || true; sandbox_run_cmd "$@" ;;
    inspect) shift || true; sandbox_inspect_cmd "$@" ;;
    list|ls) shift || true; sandbox_list_cmd "$@" ;;
    kill|delete|rm) shift || true; sandbox_kill_cmd "$@" ;;
    -h|--help|help) sandbox_usage; return 0 ;;
    *) sandbox_usage; exit 2 ;;
  esac
}

debug_cmd() {
  [ "$#" -gt 0 ] || { echo "usage: dory debug <container> [-- cmd...]" >&2; return 2; }
  echo "dory debug is unavailable: dory-agent protocol v1 has no namespace-debug RPC" >&2
  echo "use 'dory shell $1' for containers that include a shell, or 'dory exec $1 ...' for normal Docker exec" >&2
  return 2
}

usb_cmd() {
  case "${1:-ls}" in
    ls)
      local hv
      hv="$(hv_helper || true)"
      if [ -n "$hv" ]; then
        "$hv" usb list
      else
        system_profiler SPUSBDataType 2>/dev/null || ioreg -p IOUSB -l
      fi
      ;;
    attach)
      shift
      local busid="" mode=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --mode) mode="${2:?usage: dory usb attach <busid> [--mode userAuthorized|seize|capture]}"; shift 2 ;;
          --*) echo "unknown usb attach option: $1" >&2; exit 2 ;;
          *) if [ -z "$busid" ]; then busid="$1"; fi; shift ;;
        esac
      done
      [ -n "$busid" ] || { echo "usage: dory usb attach <busid> [--mode userAuthorized|seize|capture]" >&2; exit 2; }
      echo "dory usb attach is unavailable: host discovery works, but guest USB/IP attach/detach RPC is not implemented" >&2
      return 3
      ;;
    detach)
      shift
      local busid=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --*) echo "unknown usb detach option: $1" >&2; exit 2 ;;
          *) if [ -z "$busid" ]; then busid="$1"; fi; shift ;;
        esac
      done
      [ -n "$busid" ] || { echo "usage: dory usb detach <busid>" >&2; exit 2; }
      echo "dory usb detach is unavailable: guest USB/IP attach/detach RPC is not implemented" >&2
      return 3
      ;;
    *) echo "usage: dory usb ls|attach|detach" >&2; exit 2 ;;
  esac
}

expose_cmd() {
  local target="" port="" hostname="" scheme="http" print_command=0 cloudflared url
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --port) port="${2:?usage: dory expose <port|machine> [--port P] [--hostname H] [--print-command]}"; shift 2 ;;
      --hostname) hostname="${2:?usage: dory expose <port|machine> [--port P] [--hostname H] [--print-command]}"; shift 2 ;;
      --scheme) scheme="${2:?usage: dory expose <port|machine> [--scheme http|https]}"; shift 2 ;;
      --print-command) print_command=1; shift ;;
      --*) echo "unknown expose option: $1" >&2; exit 2 ;;
      *) if [ -z "$target" ]; then target="$1"; shift; else echo "unexpected argument: $1" >&2; exit 2; fi ;;
    esac
  done
  [ -n "$target" ] || { echo "usage: dory expose <port|machine> [--port P] [--hostname H] [--print-command]" >&2; exit 2; }
  [[ "$scheme" == "http" || "$scheme" == "https" ]] || { echo "invalid expose scheme: $scheme" >&2; exit 2; }
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    port="$target"
    [ "$port" -ge 1 ] && [ "$port" -le 65535 ] || { echo "invalid expose port: $port" >&2; exit 2; }
    url="$scheme://127.0.0.1:$port"
  else
    [[ "$target" =~ ^[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?$ ]] || { echo "invalid machine name: $target" >&2; exit 2; }
    port="${port:-80}"
    [[ "$port" =~ ^[0-9]+$ ]] && [ "$port" -ge 1 ] && [ "$port" -le 65535 ] || { echo "invalid expose port: $port" >&2; exit 2; }
    url="$scheme://$target.dory.local:$port"
  fi
  if [ -n "$hostname" ]; then
    [[ "$hostname" =~ ^[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?(\.[A-Za-z0-9]([A-Za-z0-9-]{0,61}[A-Za-z0-9])?)+$ ]] || {
      echo "invalid expose hostname: $hostname" >&2; exit 2
    }
  fi
  cloudflared="${DORY_CLOUDFLARED_BIN:-$(command -v cloudflared || true)}"
  [ -n "$cloudflared" ] || { echo "cloudflared not found; install it or set DORY_CLOUDFLARED_BIN" >&2; exit 1; }
  if [ -n "$hostname" ]; then
    local tunnel="${DORY_CLOUDFLARED_TUNNEL:-}"
    [ -n "$tunnel" ] || {
      echo "exposing on a named hostname requires a pre-created cloudflared tunnel with ingress mapping $hostname -> $url" >&2
      echo "create it with: cloudflared tunnel create <name> && cloudflared tunnel route dns <name> $hostname" >&2
      echo "then set DORY_CLOUDFLARED_TUNNEL=<name> and re-run" >&2
      exit 2
    }
    local cmd=("$cloudflared" tunnel run "$tunnel")
  else
    local cmd=("$cloudflared" tunnel --url "$url")
  fi
  if [ "$print_command" -eq 1 ]; then
    printf '%q ' "${cmd[@]}"
    printf '\n'
  else
    exec "${cmd[@]}"
  fi
}

doctor_cmd() {
  local helper="${DORY_DOCTOR_BIN:-$DORY_SCRIPT_DIR/dory-doctor}"
  [ -x "$helper" ] || { echo "dory-doctor helper not found: $helper" >&2; exit 1; }
  exec "$helper" "$@"
}

support_usage() {
  echo "usage: dory support bundle [--json] [--active] [PATH]" >&2
}

support_bundle_json() {
  python3 - "$1" <<'PY'
import json
import sys

path = sys.argv[1]
print(json.dumps({
    "schema": "dev.dory.support.bundle",
    "version": 1,
    "path": path,
    "redacted": True,
    "share": "Attach this zip to your GitHub issue instead of screenshots.",
}, separators=(",", ":"), sort_keys=True))
PY
}

support_cmd() {
  local action="${1:-bundle}" json=0 active=0 path="" helper out
  case "$action" in
    bundle|collect) shift || true ;;
    -h|--help|help) support_usage; return 0 ;;
    *) support_usage; exit 2 ;;
  esac
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      --active) active=1; shift ;;
      -h|--help) support_usage; return 0 ;;
      --*) echo "unknown support option: $1" >&2; support_usage; exit 2 ;;
      *)
        [ -z "$path" ] || { echo "support bundle accepts at most one path" >&2; support_usage; exit 2; }
        path="$1"
        shift
        ;;
    esac
  done
  helper="${DORY_DOCTOR_BIN:-$DORY_SCRIPT_DIR/dory-doctor}"
  [ -x "$helper" ] || { echo "dory-doctor helper not found: $helper" >&2; exit 1; }
  local args=(bundle)
  [ "$active" -eq 1 ] && args+=(--active)
  [ -n "$path" ] && args+=("$path")
  out="$("$helper" "${args[@]}")" || exit $?
  if [ "$json" -eq 1 ]; then
    support_bundle_json "$out"
  else
    printf 'Dory support bundle: %s\n' "$out"
    printf 'Attach this redacted zip to your GitHub issue instead of screenshots.\n'
  fi
}

logs_cmd() {
  case "${1:-collect}" in
    collect|bundle) shift || true; support_cmd bundle "$@" ;;
    -h|--help|help) echo "usage: dory logs collect [--json] [--active] [PATH]" >&2 ;;
    *) echo "usage: dory logs collect [--json] [--active] [PATH]" >&2; exit 2 ;;
  esac
}

idle_proxy_cmd() {
  local helper="${DORY_IDLE_PROXY_BIN:-$DORY_SCRIPT_DIR/dory-idle-proxy}"
  [ -x "$helper" ] || { echo "dory-idle-proxy helper not found: $helper" >&2; exit 1; }
  exec "$helper" "$@"
}

idle_history_cmd() {
  local json=0 limit=40 ctl out rc args
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      --limit) limit="${2:?--limit requires a count}"; shift 2 ;;
      -h|--help) echo "usage: dory idle history [--json] [--limit N]"; return 0 ;;
      *) echo "unknown idle history option: $1" >&2; exit 2 ;;
    esac
  done
  [[ "$limit" =~ ^[0-9]+$ ]] && [ "$limit" -ge 1 ] || { echo "invalid --limit: $limit" >&2; exit 2; }
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    set +e
    out="$("$ctl" --timeout 5 idle history --limit "$limit" 2>/dev/null)"
    rc=$?
    set -e
    if [ "$rc" -eq 0 ] && [ -n "$out" ]; then
      if [ "$json" -eq 1 ]; then
        printf '%s\n' "$out"
      else
        printf '%s\n' "$out" | python3 -c '
import json, sys
rows = json.load(sys.stdin)
if not rows:
    print("No Auto-Idle transitions recorded yet.")
for row in rows:
    print("{:20} {:18} {}".format(row.get("at", "?"), row.get("state") or row.get("type", "?"), row.get("detail", "")))
'
      fi
      return 0
    fi
  fi
  args=(history --limit "$limit")
  [ "$json" -eq 1 ] && args+=(--json)
  idle_proxy_cmd "${args[@]}"
}

idle_proxy_status_cmd() {
  local json=0 ctl out rc args
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) echo "usage: dory idle proxy-status [--json]"; return 0 ;;
      *) echo "unknown idle proxy-status option: $1" >&2; exit 2 ;;
    esac
  done
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    set +e
    out="$("$ctl" --timeout 5 idle status 2>/dev/null)"
    rc=$?
    set -e
    if [ "$rc" -eq 0 ] && [ -n "$out" ]; then
      if [ "$json" -eq 1 ]; then
        printf '%s\n' "$out" | python3 -c 'import json,sys; print(json.dumps((json.load(sys.stdin).get("engine_state") or {}), indent=2, sort_keys=True))'
      else
        printf '%s\n' "$out" | python3 -c 'import json,sys; data=json.load(sys.stdin).get("engine_state") or {}; print(f"Dory engine: {data.get(\"state\", \"unknown\")} ({data.get(\"detail\", \"no state\")})")'
      fi
      return 0
    fi
  fi
  args=(status)
  [ "$json" -eq 1 ] && args+=(--json)
  idle_proxy_cmd "${args[@]}"
}

idle_retired_cmd() {
  local action="$1"
  cat >&2 <<EOF
dory idle $action is retired. doryd owns Auto-Idle automatically while dev.dory.doryd is running.
Use: dory idle status, dory idle history, dory mode auto-idle, or dory engine sleep|wake.
EOF
  return 64
}

print_idle_status_json() {
  local json="$1"
  if [ "$json" -eq 1 ]; then
    cat
  else
    python3 -c '
import json, sys
data = json.load(sys.stdin)
print("Mode: {}".format(data.get("mode", "unknown")))
print("Engine desired state: {}".format(data.get("engine_desired_state", "unknown")))
print("Auto-Idle enabled: {}".format("yes" if data.get("auto_idle_enabled") else "no"))
configured = data.get("sleep_after_minutes")
effective = data.get("effective_sleep_after_minutes", configured)
if configured is not None:
    if effective != configured:
        print("Sleep after idle: {} minutes effective ({} configured)".format(effective, configured))
    else:
        print("Sleep after idle: {} minutes".format(configured))
print("Can sleep now: {}".format("yes" if data.get("can_sleep") else "no"))
state = data.get("engine_state") or {}
print("Engine: {} ({})".format(state.get("state", "unknown"), state.get("detail", "no state")))
blockers = data.get("blockers") or []
if blockers:
    print("Sleep blockers:")
    for blocker in blockers:
        print("  " + ", ".join(f"{key}={value}" for key, value in blocker.items()))
'
  fi
}

mode_cmd() {
  local mode="show" json=0 ctl out rc args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) echo "usage: dory mode [manual|auto-idle|always-on|battery-saver|show] [--json]"; return 0 ;;
      manual|auto-idle|always-on|battery-saver|show) mode="$1"; shift ;;
      *) echo "unknown mode option: $1" >&2; exit 2 ;;
    esac
  done
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    set +e
    if [ "$mode" = "show" ]; then
      out="$("$ctl" --timeout 5 idle status 2>&1)"
    else
      out="$("$ctl" --timeout 250 idle mode "$mode" 2>&1)"
    fi
    rc=$?
    set -e
    if [ "$rc" -eq 0 ] && [ -n "$out" ]; then
      printf '%s\n' "$out" | print_idle_status_json "$json"
      return 0
    fi
    if [ "$mode" != "show" ]; then
      printf 'doryd did not apply runtime mode %s: %s\n' "$mode" "${out:-request failed}" >&2
      return "$rc"
    fi
  fi
  if [ "$mode" != "show" ]; then
    echo "dorydctl is required to change runtime mode; no setting was changed" >&2
    return 1
  fi
  args=("$mode")
  [ "$json" -eq 1 ] && args+=(--json)
  doctor_cmd mode "${args[@]}"
}

idle_status_cmd() {
  local json=0 ctl out rc args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) echo "usage: dory idle status [--json]"; return 0 ;;
      *) echo "unknown idle status option: $1" >&2; exit 2 ;;
    esac
  done
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    set +e
    out="$("$ctl" --timeout 5 idle status 2>/dev/null)"
    rc=$?
    set -e
    if [ "$rc" -eq 0 ] && [ -n "$out" ]; then
      printf '%s\n' "$out" | print_idle_status_json "$json"
      return 0
    fi
  fi
  args=(status)
  [ "$json" -eq 1 ] && args+=(--json)
  doctor_cmd idle "${args[@]}"
}

idle_set_cmd() {
  local key="" value="" json=0 ctl out rc args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) echo "usage: dory idle set KEY VALUE [--json]"; return 0 ;;
      *)
        if [ -z "$key" ]; then
          key="$1"
        elif [ -z "$value" ]; then
          value="$1"
        else
          echo "too many idle set arguments" >&2
          exit 2
        fi
        shift
        ;;
    esac
  done
  [ -n "$key" ] && [ -n "$value" ] || { echo "usage: dory idle set KEY VALUE [--json]" >&2; exit 2; }
  case "$key" in
    sleepAfterMinutes)
      [[ "$value" =~ ^[0-9]+$ ]] && [ "$value" -gt 0 ] \
        || { echo "sleepAfterMinutes expects a positive integer" >&2; return 2; }
      ;;
    keepPublishedPortsAwake|keepKubernetesAwake|keepPinnedProjectsAwake|showWakeNotifications)
      case "$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]')" in
        1|true|yes|on|0|false|no|off) ;;
        *) echo "$key expects on/off (true/false)" >&2; return 2 ;;
      esac
      ;;
    *) echo "unknown idle policy key: $key" >&2; return 2 ;;
  esac
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    set +e
    out="$("$ctl" --timeout 5 idle set "$key" "$value" 2>&1)"
    rc=$?
    set -e
    if [ "$rc" -eq 0 ] && [ -n "$out" ]; then
      if [ "$json" -eq 1 ]; then
        printf '%s\n' "$out"
      else
        printf '%s\n' "$out" | python3 -c '
import json, sys
data = json.load(sys.stdin)
policy = data.get("policy") or {}
print("Set idle policy. Mode: {}".format(data.get("mode", "unknown")))
print("Sleep after idle: {} minutes".format(policy.get("sleepAfterMinutes")))
effective = data.get("effective_sleep_after_minutes")
if effective is not None and effective != policy.get("sleepAfterMinutes"):
    print("Effective sleep delay: {} minutes".format(effective))
print("Keep published ports awake: {}".format(policy.get("keepPublishedPortsAwake")))
print("Keep Kubernetes awake: {}".format(policy.get("keepKubernetesAwake")))
'
      fi
      return 0
    fi
    printf 'doryd did not apply idle policy %s: %s\n' "$key" "${out:-request failed}" >&2
    return "$rc"
  fi
  echo "dorydctl is required to change idle policy; no setting was changed" >&2
  return 1
}

engine_cmd() {
  local action="${1:-status}" json=0 ctl out state detail message rc
  [ "$#" -eq 0 ] || shift
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) echo "usage: dory engine status|wake|start|sleep|stop [--json]"; return 0 ;;
      *) echo "unknown engine option: $1" >&2; exit 2 ;;
    esac
  done
  case "$action" in
    status|wake|start|sleep|stop) ;;
    *) echo "usage: dory engine status|wake|start|sleep|stop [--json]" >&2; return 64 ;;
  esac

  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    case "$action" in
      status)
        set +e
        out="$("$ctl" --timeout 5 engine status 2>/dev/null)"
        rc=$?
        set -e
        if [ "$rc" -eq 0 ] && [ -n "$out" ]; then
          if [ "$json" -eq 1 ]; then
            printf '%s\n' "$out"
          else
            state="$(printf '%s' "$out" | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data.get("state","unknown"))' 2>/dev/null || printf '%s' "unknown")"
            detail="$(printf '%s' "$out" | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data.get("detail",""))' 2>/dev/null || true)"
            if [ -n "$detail" ]; then
              echo "Dory engine: $state — $detail"
            else
              echo "Dory engine: $state"
            fi
          fi
          return 0
        fi
        ;;
      wake|start)
        if [ "$json" -eq 1 ]; then exec "$ctl" --timeout 250 engine wake; fi
        set +e
        out="$("$ctl" --timeout 250 engine wake 2>&1)"
        rc=$?
        set -e
        if [ "$rc" -eq 0 ]; then
          message="$(printf '%s' "$out" | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data.get("message") or "wake requested")' 2>/dev/null || printf '%s' "wake requested")"
          echo "Dory engine: $message"
        else
          printf '%s\n' "$out" >&2
        fi
        return "$rc"
        ;;
      sleep|stop)
        if [ "$json" -eq 1 ]; then exec "$ctl" --timeout 90 engine sleep; fi
        set +e
        out="$("$ctl" --timeout 90 engine sleep 2>&1)"
        rc=$?
        set -e
        if [ "$rc" -eq 0 ]; then
          message="$(printf '%s' "$out" | python3 -c 'import json,sys; data=json.load(sys.stdin); print(data.get("message") or "sleep requested")' 2>/dev/null || printf '%s' "sleep requested")"
          echo "Dory engine: $message"
        else
          printf '%s\n' "$out" >&2
        fi
        return "$rc"
        ;;
    esac
  fi

  detail="doryd control is unavailable; reopen or reinstall Dory to repair its bundled CLI"
  if [ "$json" -eq 1 ] && [ "$action" = status ]; then
    python3 - "$detail" <<'PY'
import json, sys
print(json.dumps({"state": "unavailable", "detail": sys.argv[1]}, separators=(",", ":"), sort_keys=True))
PY
  else
    echo "Dory engine: $detail" >&2
  fi
  return 1
}

absolute_cli_path() {
  case "$1" in
    /*) printf '%s\n' "$1" ;;
    *) printf '%s/%s\n' "$PWD" "$1" ;;
  esac
}

upgrade_cmd() {
  local action="${1:-status}" json=0 root="${DORY_UPGRADE_ROOT:-$HOME/.dory/upgrades}"
  [ "$#" -eq 0 ] || shift
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --json) json=1; shift ;;
      -h|--help) echo "usage: dory upgrade status|recovery [--json]"; return 0 ;;
      *) echo "unknown upgrade option: $1" >&2; return 2 ;;
    esac
  done
  case "$action" in status|recovery) ;; help|-h|--help) echo "usage: dory upgrade status|recovery [--json]"; return 0 ;; *) echo "usage: dory upgrade status|recovery [--json]" >&2; return 2 ;; esac
  python3 - "$root" "$action" "$json" <<'PY'
import json
import os
import pathlib
import stat
import sys
import uuid

root = pathlib.Path(sys.argv[1])
action = sys.argv[2]
as_json = sys.argv[3] == "1"

def secure_stat(path: pathlib.Path, kind: str):
    value = path.lstat()
    expected = stat.S_IFDIR if kind == "directory" else stat.S_IFREG
    if stat.S_IFMT(value.st_mode) != expected or value.st_uid != os.getuid() or value.st_mode & 0o077:
        raise SystemExit(f"unsafe Dory upgrade {kind}: {path}")
    if kind == "file" and (value.st_nlink != 1 or value.st_size < 0 or value.st_size > 4 * 1024 * 1024):
        raise SystemExit(f"unsafe Dory upgrade file: {path}")
    return value

def read_json(path: pathlib.Path):
    secure_stat(path, "file")
    with path.open("rb") as handle:
        data = handle.read(4 * 1024 * 1024 + 1)
    if len(data) > 4 * 1024 * 1024:
        raise SystemExit(f"Dory upgrade evidence is too large: {path}")
    return json.loads(data)

records = []
if root.exists() or root.is_symlink():
    secure_stat(root, "directory")
    for entry in root.iterdir():
        try:
            transaction_id = uuid.UUID(entry.name)
        except ValueError:
            continue
        secure_stat(entry, "directory")
        record = read_json(entry / "transaction.json")
        if (record.get("kind") != "dev.dory.upgrade.transaction" or
                record.get("schemaVersion") != 1 or
                str(record.get("id", "")).lower() != str(transaction_id)):
            raise SystemExit(f"invalid Dory upgrade transaction: {entry}")
        records.append((record.get("updatedAt", ""), entry, record))

records.sort(key=lambda value: value[0], reverse=True)
if not records:
    if action == "recovery":
        raise SystemExit("no Dory upgrade recovery export is available")
    payload = {"schema": "dev.dory.upgrade.status", "version": 1, "active": False, "transaction": None}
    if as_json:
        print(json.dumps(payload, separators=(",", ":"), sort_keys=True))
    else:
        print("No Dory upgrade transaction recorded.")
    raise SystemExit(0)

_, directory, record = records[0]
terminal = record.get("state") in {"succeeded", "rolledBack", "recoveryRequired", "failed"}
if action == "status":
    payload = {"schema": "dev.dory.upgrade.status", "version": 1, "active": not terminal, "transaction": record}
    if as_json:
        print(json.dumps(payload, separators=(",", ":"), sort_keys=True))
    else:
        candidate = record.get("candidate") or {}
        print(f"Upgrade: {record.get('state', 'unknown')}")
        print(f"  transaction: {record.get('id', 'unknown')}")
        print(f"  release: {record.get('priorVersion', '?')} ({record.get('priorBuild', '?')}) -> {candidate.get('version', '?')} ({candidate.get('build', '?')})")
        print(f"  app snapshot: {'ready' if record.get('appSnapshot') else 'missing'}")
        print(f"  data snapshot: {'verified' if record.get('dataSnapshot') else 'missing'}")
        checks = record.get("smokeChecks") or []
        if checks:
            passed = sum(1 for check in checks if check.get("passed"))
            print(f"  smoke checks: {passed}/{len(checks)} passed")
        if record.get("error"):
            print(f"  detail: {record['error']}")
        if record.get("recoveryDirectory"):
            print(f"  recovery: {record['recoveryDirectory']}/recovery.json")
    raise SystemExit(0)

expected = directory / "recovery"
recovery_directory = record.get("recoveryDirectory")
if recovery_directory != str(expected):
    raise SystemExit("latest Dory upgrade has no validated recovery export")
secure_stat(expected, "directory")
recovery = read_json(expected / "recovery.json")
if (recovery.get("schema") != "dev.dory.upgrade.recovery" or recovery.get("version") != 1 or
        recovery.get("transactionID") != record.get("id") or recovery.get("durableDataWasRolledBack") is not False):
    raise SystemExit("Dory upgrade recovery export is invalid")
if as_json:
    print(json.dumps({"schema": "dev.dory.upgrade.recovery-status", "version": 1, "recovery": recovery}, separators=(",", ":"), sort_keys=True))
else:
    print(f"Recovery export: {expected / 'recovery.json'}")
    print(f"Reason: {recovery.get('reason', 'unknown')}")
    print(f"Durable data rolled back: no")
    print(f"Verify: {recovery.get('exportCommand', 'unavailable')}")
    print(f"Restore to a new drive: {recovery.get('restoreCommand', 'unavailable')}")
PY
}

data_cmd() {
  local action="${1:-path}" helper source archive target capacity output json=0
  [ "$#" -eq 0 ] || shift
  helper="$(hv_helper || true)"
  [ -n "$helper" ] || {
    echo "Dory's signed data-drive helper is unavailable; reinstall Dory or open the app once." >&2
    exit 1
  }
  case "$action" in
    path)
      [ "$#" -eq 0 ] || { echo "usage: dory data path" >&2; exit 2; }
      "$helper" data-drive selected-path || {
        echo "No Dory data drive is selected yet; open Dory once to initialize it." >&2
        exit 1
      }
      ;;
    backup)
      [ "$#" -eq 1 ] || { echo "usage: dory data backup <archive.dorybackup>" >&2; exit 2; }
      source="$("$helper" data-drive selected-path)" || {
        echo "No Dory data drive is selected yet; open Dory once to initialize it." >&2
        exit 1
      }
      archive="$(absolute_cli_path "$1")"
      "$helper" data-drive backup "$source" "$archive"
      ;;
    verify)
      [ "$#" -eq 1 ] || { echo "usage: dory data verify <archive.dorybackup>" >&2; exit 2; }
      archive="$(absolute_cli_path "$1")"
      "$helper" data-drive verify-backup "$archive"
      ;;
    restore)
      [ "$#" -eq 2 ] || {
        echo "usage: dory data restore <archive.dorybackup> <target.dorydrive>" >&2
        exit 2
      }
      archive="$(absolute_cli_path "$1")"
      target="$(absolute_cli_path "$2")"
      "$helper" data-drive restore "$archive" "$target"
      ;;
    use)
      [ "$#" -eq 1 ] || { echo "usage: dory data use <target.dorydrive>" >&2; exit 2; }
      target="$(absolute_cli_path "$1")"
      select_data_drive "$helper" "$target"
      ;;
    capacity)
      if [ "${1:-}" = "--json" ]; then json=1; shift; fi
      [ "$#" -eq 0 ] || { echo "usage: dory data capacity [--json]" >&2; exit 2; }
      output="$("$helper" data-drive capacity)"
      if [ "$json" -eq 1 ]; then printf '%s\n' "$output"; else format_data_drive_capacity "$output"; fi
      ;;
    grow)
      [ "$#" -ge 1 ] || { echo "usage: dory data grow <capacity-gib> [--json]" >&2; exit 2; }
      capacity="$1"
      shift
      if [ "${1:-}" = "--json" ]; then json=1; shift; fi
      [ "$#" -eq 0 ] || { echo "usage: dory data grow <capacity-gib> [--json]" >&2; exit 2; }
      output="$(grow_data_drive "$helper" "$capacity")"
      if [ "$json" -eq 1 ]; then printf '%s\n' "$output"; else format_data_drive_capacity "$output"; fi
      ;;
    -h|--help|help)
      echo "usage: dory data path|backup|verify|restore|use|capacity|grow ..."
      ;;
    *)
      echo "usage: dory data path|backup|verify|restore|use|capacity|grow ..." >&2
      exit 2
      ;;
  esac
}

format_data_drive_capacity() {
  python3 - "$1" <<'PY'
import json
import sys

usage = json.loads(sys.argv[1])
state = "initialized" if usage["initialized"] else "default before first start"
print(
    f'Docker storage: {usage["capacityGiB"]} GiB logical capacity, '
    f'{usage["allocatedBytes"] / (1024 ** 3):.2f} GiB physically allocated ({state}).'
)
print(
    f'Supported growth range: {usage["minimumCapacityGiB"]}–'
    f'{usage["maximumCapacityGiB"]} GiB. Shrinking is intentionally refused.'
)
PY
}

restart_after_data_grow() {
  local ctl="$1" running_ids="$2" cid failures=""
  if ! "$ctl" --timeout 250 engine start >/dev/null; then
    echo "Dory could not restart the engine after changing Docker storage capacity." >&2
    return 1
  fi
  while IFS= read -r cid; do
    [ -n "$cid" ] || continue
    case "$cid" in *[!0-9a-f]*) failures="$failures $cid"; continue ;; esac
    "$DOCKER_BIN" -H "unix://$DORY_SOCK" start "$cid" >/dev/null 2>&1 \
      || failures="$failures $cid"
  done <<< "$running_ids"
  if [ -n "$failures" ]; then
    echo "These previously running containers did not restart after the engine came back:$failures" >&2
    return 1
  fi
}

grow_data_drive() {
  local helper="$1" requested="$2" ctl="" status="" state="" running_ids=""
  local current minimum maximum capacity_json
  local stopped=0 output rc restart_rc=0
  case "$requested" in ''|*[!0-9]*) echo "Docker storage capacity must be an integer GiB value." >&2; return 2 ;; esac

  capacity_json="$("$helper" data-drive capacity)" || return $?
  read -r current minimum maximum <<EOF
$(python3 - "$capacity_json" <<'PY'
import json
import sys

usage = json.loads(sys.argv[1])
print(usage["capacityGiB"], usage["minimumCapacityGiB"], usage["maximumCapacityGiB"])
PY
)
EOF
  [ -n "$current" ] || return 1
  if [ "$requested" -lt "$minimum" ] || [ "$requested" -gt "$maximum" ]; then
    echo "Docker storage capacity must be between $minimum and $maximum GiB." >&2
    return 2
  fi
  if [ "$requested" -lt "$current" ]; then
    echo "Docker storage shrinking is not supported ($current GiB to $requested GiB). Back up and restore into a new drive instead." >&2
    return 2
  fi
  if [ "$requested" -eq "$current" ]; then
    printf '%s\n' "$capacity_json"
    return 0
  fi

  if ctl="$(dorydctl_bin 2>/dev/null)" \
      && status="$("$ctl" --timeout 5 engine status 2>/dev/null)"; then
    state="$(python3 - "$status" <<'PY'
import json, sys
print(json.loads(sys.argv[1]).get("state", ""))
PY
)" || return 1
    case "$state" in
      running)
        running_ids="$("$DOCKER_BIN" -H "unix://$DORY_SOCK" ps -q)" || {
          echo "Dory could not verify running containers, so Docker storage was not changed." >&2
          return 1
        }
        ;;
      stopped|sleeping|failed) ;;
      starting)
        echo "Dory's engine is still starting; wait for it to become ready before changing Docker storage." >&2
        return 1
        ;;
      *)
        echo "Dory reported an unrecognized engine state ('$state'), so Docker storage was not changed." >&2
        return 1
        ;;
    esac
    case "$state" in
      running)
        echo "Stopping Dory's Docker engine before growing its data disk…" >&2
        "$ctl" --timeout 250 engine stop >/dev/null || {
          echo "Dory could not stop the Docker engine safely; storage was not changed." >&2
          return 1
        }
        stopped=1
        ;;
    esac
  else
    ctl=""
  fi

  set +e
  output="$("$helper" data-drive grow "$requested" 2>&1)"
  rc=$?
  set -e
  if [ "$rc" -ne 0 ]; then
    if [ "$stopped" -eq 1 ]; then
      restart_after_data_grow "$ctl" "$running_ids" || restart_rc=$?
    fi
    printf '%s\n' "$output" >&2
    [ "$restart_rc" -eq 0 ] || return "$restart_rc"
    return "$rc"
  fi

  if [ "$stopped" -eq 1 ]; then
    restart_after_data_grow "$ctl" "$running_ids" || return $?
  fi
  printf '%s\n' "$output"
}

select_data_drive() {
  local helper="$1" target="$2"
  local launchctl_bin="${DORY_LAUNCHCTL_BIN:-/bin/launchctl}"
  local plist="$HOME/Library/LaunchAgents/dev.dory.doryd.plist"
  local domain service
  domain="gui/$(id -u)"
  service="$domain/dev.dory.doryd"
  local daemon_was_loaded=0 output rc restart_error="" label program ctl attempt

  if [ -e "$plist" ] || [ -L "$plist" ]; then
    [ ! -L "$plist" ] && [ -f "$plist" ] || {
      echo "Dory cannot change drives while its LaunchAgent path is not a regular file: $plist" >&2
      return 1
    }
    label="$(/usr/bin/plutil -extract Label raw -o - "$plist" 2>/dev/null || true)"
    program="$(/usr/bin/plutil -extract ProgramArguments.0 raw -o - "$plist" 2>/dev/null || true)"
    [ "$label" = dev.dory.doryd ] || {
      echo "Dory cannot restart a LaunchAgent with an unexpected label: $plist" >&2
      return 1
    }
    case "$program" in
      /*/Dory.app/Contents/Helpers/doryd) ;;
      *) echo "Dory cannot restart a LaunchAgent with an unexpected daemon: $program" >&2; return 1 ;;
    esac
    if "$launchctl_bin" print "$service" >/dev/null 2>&1; then
      daemon_was_loaded=1
      echo "Stopping Dory's engine and machines before changing the data drive…"
      if ! output="$("$launchctl_bin" bootout "$service" 2>&1)"; then
        echo "Dory could not stop its LaunchAgent: $output" >&2
        return 1
      fi
    fi
  fi

  set +e
  output="$("$helper" data-drive bind-existing "$target" 2>&1)"
  rc=$?
  set -e
  if [ "$rc" -ne 0 ]; then
    if [ "$daemon_was_loaded" -eq 1 ]; then
      if ! restart_error="$("$launchctl_bin" bootstrap "$domain" "$plist" 2>&1)"; then
        echo "Dory also could not restore its LaunchAgent after the failed drive change: $restart_error" >&2
      else
        "$launchctl_bin" kickstart "$service" >/dev/null 2>&1 || true
      fi
    fi
    printf '%s\n' "$output" >&2
    return "$rc"
  fi

  if [ "$daemon_was_loaded" -eq 1 ]; then
    if ! restart_error="$("$launchctl_bin" bootstrap "$domain" "$plist" 2>&1)"; then
      if ! "$launchctl_bin" print "$service" >/dev/null 2>&1; then
        echo "Selected the drive, but Dory's LaunchAgent did not restart: $restart_error" >&2
        return 1
      fi
    fi
    "$launchctl_bin" kickstart "$service" >/dev/null 2>&1 || true
    if ! ctl="$(dorydctl_bin 2>/dev/null)"; then
      echo "Selected the drive, but Dory could not find dorydctl to verify the restarted daemon." >&2
      return 1
    fi
    for ((attempt = 0; attempt < 120; attempt++)); do
      "$ctl" --timeout 2 protocol-version >/dev/null 2>&1 && break
      sleep 0.25
    done
    if [ "$attempt" -ge 120 ]; then
      echo "Selected the drive, but doryd did not become ready within 30 seconds." >&2
      return 1
    fi
  fi

  printf 'Selected Dory data drive %s at %s\n' "$output" "$target"
}

wait_emit_json() {
  python3 - "$1" "$2" "$3" "$4" "$5" "$6" "$7" <<'PY'
import json
import sys

kind, target, desired, state, matched, elapsed, timeout = sys.argv[1:8]
ok = matched == "1"
print(json.dumps({
    "schema": "dev.dory.wait",
    "version": 1,
    "ok": ok,
    "status": "matched" if ok else "timeout",
    "code": "wait.matched" if ok else "wait.timeout",
    "kind": kind,
    "target": target,
    "desiredState": desired,
    "state": state,
    "matched": ok,
    "elapsedSeconds": int(elapsed),
    "timeoutSeconds": int(timeout),
}, separators=(",", ":"), sort_keys=True))
PY
}

engine_current_state() {
  local ctl out state
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    out="$("$ctl" --timeout 2 engine status 2>/dev/null || true)"
    state="$(printf '%s' "$out" | python3 -c 'import json,sys
try:
    print(json.load(sys.stdin).get("state", ""))
except Exception:
    pass' 2>/dev/null || true)"
    [ -n "$state" ] && { printf '%s\n' "$state"; return 0; }
  fi
  printf '%s\n' "not-running"
}

container_current_state() {
  local target="$1" state
  state="$("$DOCKER_BIN" -H "unix://$DORY_SOCK" inspect -f '{{.State.Status}}' "$target" 2>/dev/null || true)"
  [ -n "$state" ] && printf '%s\n' "$state" || printf '%s\n' "missing"
}

machine_current_state() {
  local target="$1" ctl out state cid
  if ctl="$(dorydctl_bin 2>/dev/null)"; then
    out="$("$ctl" --timeout 2 machine status "$target" 2>/dev/null || true)"
    state="$(printf '%s' "$out" | python3 -c 'import json,sys
try:
    print(json.load(sys.stdin).get("state", ""))
except Exception:
    pass' 2>/dev/null || true)"
    [ -n "$state" ] && { printf '%s\n' "$state"; return 0; }
  fi
  cid="$(machine_container_name "$target")"
  state="$("$DOCKER_BIN" -H "unix://$DORY_SOCK" inspect -f '{{.State.Status}}' "$cid" 2>/dev/null || true)"
  [ -n "$state" ] && printf '%s\n' "$state" || printf '%s\n' "missing"
}

wait_state_matches() {
  local kind="$1" state="$2" desired="$3"
  case "$desired:$state" in
    running:running|running:awake|awake:running|awake:awake) return 0 ;;
    sleeping:sleeping|idle:sleeping) return 0 ;;
    stopped:stopped|stopped:exited|exited:exited|exited:stopped) return 0 ;;
    missing:missing|removed:missing|not-running:not-running) return 0 ;;
  esac
  [ "$state" = "$desired" ] && return 0
  if [ "$kind" = "engine" ] && [ "$desired" = "stopped" ] && [ "$state" = "not-running" ]; then
    return 0
  fi
  return 1
}

wait_usage() {
  echo "usage: dory wait engine|container|machine [NAME] --until STATE --timeout N [--interval N] [--json]" >&2
}

wait_cmd() {
  local kind="${1:-}" target="" desired="" timeout=60 interval=1 json=0 start now elapsed state
  [ -n "$kind" ] || { wait_usage; exit 2; }
  shift
  case "$kind" in
    engine) target="engine" ;;
    container|machine)
      target="${1:-}"
      [ -n "$target" ] || { wait_usage; exit 2; }
      shift
      ;;
    *) wait_usage; exit 2 ;;
  esac

  case "$kind" in
    engine) desired="running" ;;
    container|machine) desired="running" ;;
  esac

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --until) desired="${2:?--until requires a state}"; shift 2 ;;
      --timeout) timeout="${2:?--timeout requires seconds}"; shift 2 ;;
      --interval) interval="${2:?--interval requires seconds}"; shift 2 ;;
      --json) json=1; shift ;;
      -h|--help) wait_usage; return 0 ;;
      *) echo "unknown wait option: $1" >&2; wait_usage; exit 2 ;;
    esac
  done
  [[ "$timeout" =~ ^[0-9]+$ ]] || { echo "invalid --timeout: $timeout" >&2; exit 2; }
  [[ "$interval" =~ ^[0-9]+$ ]] && [ "$interval" -ge 1 ] || { echo "invalid --interval: $interval" >&2; exit 2; }
  [ -n "$desired" ] || { wait_usage; exit 2; }

  start="$(date +%s)"
  while :; do
    case "$kind" in
      engine) state="$(engine_current_state)" ;;
      container) state="$(container_current_state "$target")" ;;
      machine) state="$(machine_current_state "$target")" ;;
    esac
    now="$(date +%s)"
    elapsed=$((now - start))
    if wait_state_matches "$kind" "$state" "$desired"; then
      if [ "$json" -eq 1 ]; then
        wait_emit_json "$kind" "$target" "$desired" "$state" 1 "$elapsed" "$timeout"
      else
        echo "$kind $target reached $state"
      fi
      return 0
    fi
    if [ "$elapsed" -ge "$timeout" ]; then
      if [ "$json" -eq 1 ]; then
        wait_emit_json "$kind" "$target" "$desired" "$state" 0 "$elapsed" "$timeout"
      else
        echo "timed out waiting for $kind $target to reach $desired (last state: $state)" >&2
      fi
      return 1
    fi
    sleep "$interval"
  done
}

events_cmd() {
  local follow=0 json=0 limit=50 interval=1
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --follow) follow=1; shift ;;
      --json) json=1; shift ;;
      --limit) limit="${2:?--limit requires a count}"; shift 2 ;;
      --interval) interval="${2:?--interval requires seconds}"; shift 2 ;;
      -h|--help) echo "usage: dory events [--json] [--follow] [--limit N] [--interval N]"; return 0 ;;
      *) echo "unknown events option: $1" >&2; exit 2 ;;
    esac
  done
  [[ "$limit" =~ ^[0-9]+$ ]] && [ "$limit" -ge 1 ] || { echo "invalid --limit: $limit" >&2; exit 2; }
  [[ "$interval" =~ ^[0-9]+$ ]] && [ "$interval" -ge 1 ] || { echo "invalid --interval: $interval" >&2; exit 2; }

  python3 - "$follow" "$json" "$limit" "$interval" <<'PY'
import json
import os
import sys
import time
from pathlib import Path

follow = sys.argv[1] == "1"
as_json = sys.argv[2] == "1"
limit = int(sys.argv[3])
interval = int(sys.argv[4])
home = Path.home()
idle_state = Path(os.environ.get("DORY_IDLE_STATE", str(home / ".dory" / "idle-state.json"))).expanduser()
idle_history = idle_state.with_name("idle-history.jsonl")
incidents = Path(os.environ.get("DORY_INCIDENTS", str(home / ".dory" / "incidents.jsonl"))).expanduser()


def read_jsonl(path: Path) -> list[dict]:
    out: list[dict] = []
    try:
        for line in path.read_text(encoding="utf-8").splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                value = json.loads(line)
            except json.JSONDecodeError:
                continue
            if isinstance(value, dict):
                out.append(value)
    except FileNotFoundError:
        pass
    except OSError:
        pass
    return out


def idle_event(record: dict) -> dict:
    state = str(record.get("state") or "unknown")
    return {
        "schema": "dev.dory.event",
        "version": 1,
        "source": "idle",
        "type": f"idle.{state}",
        "at": record.get("at") or record.get("updated_at") or "",
        "state": state,
        "detail": record.get("detail") or "",
        "raw": record,
    }


def incident_event(record: dict) -> dict:
    event_type = str(record.get("type") or "incident")
    return {
        "schema": "dev.dory.event",
        "version": 1,
        "source": "incident",
        "type": event_type,
        "at": record.get("at") or "",
        "detail": record.get("detail") or "",
        "raw": record,
    }


def snapshot() -> list[dict]:
    events = [idle_event(item) for item in read_jsonl(idle_history)]
    events.extend(incident_event(item) for item in read_jsonl(incidents))
    events.sort(key=lambda item: (str(item.get("at") or ""), item["source"], item["type"]))
    return events[-limit:]


def emit_event(event: dict) -> None:
    if as_json:
        print(json.dumps(event, separators=(",", ":"), sort_keys=True), flush=True)
    else:
        print(f"{event.get('at') or '?':20} {event['source']:<8} {event['type']:<24} {event.get('detail', '')}", flush=True)


if not follow:
    events = snapshot()
    if as_json:
        print(json.dumps({"schema": "dev.dory.events", "version": 1, "events": events}, separators=(",", ":"), sort_keys=True))
    elif events:
        for event in events:
            emit_event(event)
    else:
        print("No Dory events recorded yet.")
    raise SystemExit(0)

for event in snapshot():
    emit_event(event)

offsets: dict[Path, int] = {}
for path in (idle_history, incidents):
    try:
        offsets[path] = path.stat().st_size
    except FileNotFoundError:
        offsets[path] = 0

while True:
    for path, convert in ((idle_history, idle_event), (incidents, incident_event)):
        try:
            size = path.stat().st_size
        except FileNotFoundError:
            offsets[path] = 0
            continue
        if size < offsets.get(path, 0):
            offsets[path] = 0
        with path.open("r", encoding="utf-8") as handle:
            handle.seek(offsets.get(path, 0))
            lines = handle.readlines()
            offsets[path] = handle.tell()
        for line in lines:
            line = line.strip()
            if not line:
                continue
            try:
                record = json.loads(line)
            except json.JSONDecodeError:
                continue
            if isinstance(record, dict):
                emit_event(convert(record))
    time.sleep(interval)
PY
}

mcp_cmd() {
  local sub="${1:-serve}" read_only="${DORY_MCP_READ_ONLY:-0}"
  case "$sub" in
    serve) shift || true ;;
    -h|--help)
      echo "usage: dory mcp serve [--read-only]"
      return 0
      ;;
    *)
      echo "usage: dory mcp serve [--read-only]" >&2
      exit 2
      ;;
  esac
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --read-only) read_only=1; shift ;;
      --write) read_only=0; shift ;;
      -h|--help) echo "usage: dory mcp serve [--read-only]"; return 0 ;;
      *) echo "unknown mcp option: $1" >&2; exit 2 ;;
    esac
  done

  python3 /dev/fd/3 "$DORY_SCRIPT_SOURCE" "$read_only" "$DORY_CLI_VERSION" 3<<'PY'
import json
import os
import subprocess
import sys
from typing import Any, Optional

CLI = sys.argv[1]
READ_ONLY = sys.argv[2] in ("1", "true", "yes", "on")
SERVER_VERSION = sys.argv[3] if len(sys.argv) > 3 and sys.argv[3] else "0.0.0"
PROTOCOL = "2025-11-25"
SUPPORTED_PROTOCOLS = {PROTOCOL, "2025-06-18"}


class ToolExecutionError(Exception):
    pass


def schema_object(properties: Optional[dict[str, Any]] = None, required: Optional[list[str]] = None) -> dict[str, Any]:
    schema: dict[str, Any] = {
        "type": "object",
        "additionalProperties": False,
    }
    if properties:
        schema["properties"] = properties
    if required:
        schema["required"] = required
    return schema


TOOLS: list[dict[str, Any]] = [
