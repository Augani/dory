@@ -0,0 +1,15 @@
+package tap
+
+import (
+	"testing"
+
+	"github.com/stretchr/testify/require"
+	"gvisor.dev/gvisor/pkg/tcpip"
+)
+
+func TestEthernetMulticastClassification(t *testing.T) {
+	require.True(t, isEthernetMulticast(tcpip.LinkAddress("\x33\x33\xff\x00\x00\x01")))
+	require.True(t, isEthernetMulticast(tcpip.LinkAddress("\x01\x00\x5e\x00\x00\xfb")))
+	require.False(t, isEthernetMulticast(tcpip.LinkAddress("\x5a\x94\xef\xe4\x0c\xdd")))
+	require.False(t, isEthernetMulticast(tcpip.LinkAddress("short")))
+}
