+package virtualnetwork
+
+import (
+	"testing"
+
+	"github.com/containers/gvisor-tap-vsock/pkg/tap"
+	"github.com/containers/gvisor-tap-vsock/pkg/types"
+	"github.com/stretchr/testify/require"
+)
+
+func TestCreateStackDualStack(t *testing.T) {
+	endpoint, err := tap.NewLinkEndpoint(false, 1500, "5a:94:ef:e4:0c:dd", "192.168.127.1", nil)
+	require.NoError(t, err)
+	_, err = createStack(&types.Configuration{
+		Subnet:        "192.168.127.0/24",
+		GatewayIP:     "192.168.127.1",
+		IPv6Subnet:    "fd7d:6f72:7900::/64",
+		IPv6GatewayIP: "fd7d:6f72:7900::1",
+	}, endpoint)
+	require.NoError(t, err)
+}
+
+func TestCreateStackRejectsIncompleteOrInvalidIPv6(t *testing.T) {
+	for _, configuration := range []types.Configuration{
+		{Subnet: "192.168.127.0/24", GatewayIP: "192.168.127.1", IPv6Subnet: "fd7d:6f72:7900::/64"},
+		{Subnet: "192.168.127.0/24", GatewayIP: "192.168.127.1", IPv6GatewayIP: "fd7d:6f72:7900::1"},
+		{Subnet: "192.168.127.0/24", GatewayIP: "192.168.127.1", IPv6Subnet: "fd7d:6f72:7900::/129", IPv6GatewayIP: "fd7d:6f72:7900::1"},
+	} {
+		endpoint, err := tap.NewLinkEndpoint(false, 1500, "5a:94:ef:e4:0c:dd", "192.168.127.1", nil)
+		require.NoError(t, err)
+		_, err = createStack(&configuration, endpoint)
+		require.Error(t, err)
+	}
+}
