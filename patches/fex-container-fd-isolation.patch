+++ b/Source/Common/FDUtils.h
@@ -9,9 +9,61 @@
 
 namespace FEX {
 
+inline int HostProcFD {-1};
+
+inline void SetHostProcFD(int fd) {
+  HostProcFD = fd;
+}
+
+[[nodiscard]]
+inline int GetHostProcFD() {
+  return HostProcFD;
+}
+
+[[nodiscard]]
+inline int OpenHostProcFile(const char* RelativePath, int Flags) {
+  if (HostProcFD != -1) {
+    return openat(HostProcFD, RelativePath, Flags);
+  }
+
+  auto Path = fextl::fmt::format("/proc/{}", RelativePath);
+  return open(Path.c_str(), Flags);
+}
+
+// FEX shares the host descriptor table with the translated process. Keep long-lived runtime
+// handles out of the low range so guest allocation matches native Linux. This matters for POSIX
+// shells such as dash, which only accept single-digit redirection operands: package managers may
+// legitimately pass a newly allocated descriptor to `sh -c`, and one leaked runtime handle can
+// turn fd 9 into fd 10.
+[[nodiscard]]
+inline int RelocateInternalFD(int fd) {
+  constexpr int INTERNAL_FD_BASE = 256;
+  if (fd < 0 || fd >= INTERNAL_FD_BASE) {
+    return fd;
+  }
+
+  const int OriginalFlags = fcntl(fd, F_GETFD);
+  const int Relocated = fcntl(fd, F_DUPFD_CLOEXEC, INTERNAL_FD_BASE);
+  if (Relocated == -1) {
+    return fd;
+  }
+  if (OriginalFlags != -1 && fcntl(Relocated, F_SETFD, OriginalFlags) == -1) {
+    close(Relocated);
+    return fd;
+  }
+
+  close(fd);
+  return Relocated;
+}
+
 [[nodiscard]]
 inline int get_fdpath(int fd, char* SymlinkPath) {
-  auto Path = fextl::fmt::format("/proc/self/fd/{}", fd);
+  auto Path = fextl::fmt::format("self/fd/{}", fd);
+  if (HostProcFD != -1) {
+    return readlinkat(HostProcFD, Path.c_str(), SymlinkPath, PATH_MAX);
+  }
+
+  Path = fextl::fmt::format("/proc/{}", Path);
   return readlinkat(AT_FDCWD, Path.c_str(), SymlinkPath, PATH_MAX);
 }
 
